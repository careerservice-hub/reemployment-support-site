---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { title, description, jsonLd } = Astro.props;
const pageTitle = title ? `${title} | K·JOBS` : '재취업지원서비스 시행지원 | K·JOBS';
const pageDescription = description ?? '케이잡스 K·JOBS가 기업컨설팅과 커리어플래닝서비스를 통해 기업의 제도 운영과 중장년 근로자의 경력설계를 지원합니다.';
const currentUrl = new URL(Astro.url.pathname, 'https://www.careerservice.co.kr').toString();
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={currentUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:locale" content="ko_KR" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://i.ytimg.com; frame-src https://www.youtube.com https://www.youtube-nocookie.com; connect-src 'self' https://kjobs-consultation-alert.kjobs-alert.workers.dev; object-src 'none'; base-uri 'self'; form-action 'self';" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <title>{pageTitle}</title>
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    <a class="skip-link" href="#main-content">본문 바로가기</a>
    <div class="page-shell">
      <Header />
      <main id="main-content" tabindex="-1">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
