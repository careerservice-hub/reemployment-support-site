---
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${base}${path}`;
const nav = [
  { href: link(''), label: '홈' },
  { href: link('career-support/'), label: '경력지원' },
  { href: link('business-consulting/'), label: '기업컨설팅' },
  { href: link('career-planning/'), label: '커리어플래닝' },
  { href: link('process/'), label: '진행 절차', groupStart: true },
  { href: link('approach/'), label: '지원 방식' },
  { href: link('policy-updates/'), label: '정책소식', groupStart: true },
  { href: link('faq/'), label: 'FAQ' },
  { href: link('contact/'), label: '문의', cta: true },
];
const mobileNav = [
  { href: link('career-support/'), label: '경력' },
  { href: link('business-consulting/'), label: '기업' },
  { href: link('career-planning/'), label: '개인' },
  { href: link('policy-updates/'), label: '정책' },
  { href: link('faq/'), label: 'FAQ' },
  { href: link('contact/'), label: '문의', cta: true },
];
const normalizePath = (path) => path.replace(/\/+$/, '') || '/';
const currentPath = normalizePath(Astro.url.pathname);
const isCurrent = (href) => normalizePath(new URL(href, Astro.url).pathname) === currentPath;
---
<header class="site-header">
  <a class="brand" href={base} aria-label="재취업지원서비스 시행지원 홈">
    <img class="brand-logo" src={`${base}assets/kjobs-logo-official.png`} alt="케이잡스 K·JOBS 로고" width="84" height="44" loading="eager" />
    <span class="brand-text">
      <span class="brand-kicker">재취업지원서비스 시행지원</span>
      <span class="brand-title">기업컨설팅 · 커리어플래닝서비스</span>
    </span>
  </a>
  <nav class="nav desktop-nav" aria-label="주요 메뉴">
    {nav.map((item) => <a href={item.href} class:list={[item.cta && 'nav-cta', item.groupStart && 'nav-group-start']} aria-current={isCurrent(item.href) ? 'page' : undefined}>{item.label}</a>)}
  </nav>
  <nav class="nav mobile-nav" aria-label="모바일 주요 메뉴">
    {mobileNav.map((item) => <a href={item.href} class={item.cta ? 'nav-cta' : undefined} aria-current={isCurrent(item.href) ? 'page' : undefined}>{item.label}</a>)}
  </nav>
</header>
