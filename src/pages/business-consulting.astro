---
import BaseLayout from '../layouts/BaseLayout.astro';
import { businessConsultingJsonLd } from '../data/structuredData.js';
const readinessItems = [
  ['재취업지원서비스 도입 또는 개선을 검토하는 기업', '처음 도입하는 기업은 기본 운영체계를, 이미 운영 중인 기업은 안내·참여·성과관리 방식의 개선점을 중심으로 점검합니다.'],
  ['대상자 규모, 내부 역할, 운영 절차를 정리해야 하는 기업', '퇴직예정자 규모와 발생 시점, 담당 부서 역할, 내부 결재·안내 흐름을 먼저 정리해야 실행 가능한 제도 설계가 가능합니다.'],
  ['담당자 안내, 참여자 모집, 일정 운영 방식을 구체화하려는 기업', '현장 담당자가 바로 설명할 수 있는 안내 문구, 참여자 모집 방식, 회차별 일정 운영 기준을 기업 상황에 맞게 구체화합니다.'],
  ['파일럿 운영을 통해 현장 적용 가능성을 확인하려는 기업', '일부 대상자에게 먼저 적용해 안내문, 상담 흐름, 산출물 정리 방식이 실제 사업장에서 작동하는지 확인합니다.'],
];
const steps = [
  ['01', '착수', '기업 현황과 컨설팅 범위를 확인하고 진행 기준을 맞춥니다.', '담당자, 케이잡스, 컨설턴트가 컨설팅 목적과 범위를 함께 확인합니다. 이후 일정, 자료 준비, 주요 의사결정 지점을 정리해 전체 진행 기준을 맞춥니다.'],
  ['02', '환경분석', '제도 운영 여건, 대상자 규모, 내부 준비 수준을 진단합니다.', '기업의 인력구조, 대상자 발생 가능성, 기존 지원제도, 담당 조직을 확인합니다. 이 단계의 진단 결과가 계획수립과 파일럿 범위를 정하는 기준이 됩니다.'],
  ['03', '계획수립', '기업 상황에 맞는 컨설팅 일정과 운영 방향을 정리합니다.', '방문 일정, 인터뷰·FGI 범위, 참여자 안내 방식, 중간 점검 시점을 정합니다. 기업 여건에 맞는 운영 방향을 문서화해 실행 가능한 계획으로 바꿉니다.'],
  ['04', '중간보고', '진단 결과와 설계 방향을 점검하고 보완 과제를 확인합니다.', '환경분석 결과와 초기 설계안을 공유하고 기업 의견을 반영합니다. 이후 파일럿 운영과 제도설계에서 보완해야 할 쟁점을 확정합니다.'],
  ['05', '파일럿운영', '설계한 서비스 흐름을 일부 대상자에게 시범 적용합니다.', '설계한 서비스 흐름을 일부 대상자에게 적용해 안내문, 상담 절차, 결과 정리 방식의 운영 가능성을 점검합니다.'],
  ['06', '제도설계', '기업이 자체 시행할 수 있는 운영체계와 절차를 구체화합니다.', '담당 부서 역할, 대상자 선정, 프로그램 구성, 기록·성과관리 방식을 정리합니다. 기업이 이후 자체적으로 시행할 수 있는 운영 기준을 남깁니다.'],
  ['07', '최종보고', '실행 결과, 개선사항, 제도화 과제를 최종 정리합니다.', '컨설팅 결과, 파일럿 운영 확인사항, 보완 과제, 향후 실행 일정을 정리합니다. 내부 보고와 후속 운영에 활용할 수 있는 최종 산출물로 마무리합니다.'],
];
const supportTypes = [
  ['기초컨설팅', '시행 경험이 없거나 도입을 준비하는 기업의 인식 개선, 도입 체계, 운영 체계 구축을 지원합니다.', '제도를 처음 준비하는 기업이 대상입니다. 제도 이해, 담당자 역할, 대상자 안내 방식, 기본 운영 흐름을 잡는 데 초점을 둡니다.'],
  ['전문컨설팅', '시행 경험이 있는 기업의 개선사항 진단, 전담인력 역량강화, 운영체계 강화, 성과관리를 점검합니다.', '기존 운영 경험을 바탕으로 제도 개선, 담당자 역량, 프로그램 품질, 성과관리 기준을 고도화하는 데 적합합니다.'],
  ['공동컨설팅', '원·하청, 산업단지 등 공동 운영 여건에 맞춰 별도 기준과 모듈식 방식으로 조정합니다.', '여러 기업이 함께 운영해야 하는 경우 적용합니다. 공통 기준과 기업별 차이를 구분해 공동 운영 가능한 구조로 조정합니다.'],
];
const practicalChecks = [
  {
    title: '의무기업 여부와 대상자 발생 가능성',
    body: '전년도 고용보험 피보험자 수, 50세 이상 근로자 현황, 퇴직예정자 발생 시점을 먼저 확인합니다.',
    criteria: ['전년도 월평균 고용보험 피보험자 수', '연령대별 근로자 수와 전체 근로자 대비 비율', '해당 연도 퇴직예정자 수와 예상 퇴직 시점', '향후 1~3년간 예상되는 대상자 규모'],
    materials: '고용보험 가입인원 자료, 연령별 인원 현황, 퇴직예정자 인원 집계표',
  },
  {
    title: '담당부서와 내부 의사결정 흐름',
    body: '인사·노무 담당자, 결재선, 노사협의 필요 여부를 정리해 안내와 실행이 끊기지 않게 합니다.',
    criteria: ['제도 운영을 담당할 부서와 실무담당자', '시행계획과 예산을 승인하는 내부 결재선', '참여자 안내와 일정을 조정할 현장 책임자', '노사협의회 또는 노동조합 협의 필요 여부'],
    materials: '조직도, 업무분장표, 내부 결재 절차, 노사협의회 운영 현황',
  },
  {
    title: '서비스 제공 방식과 증빙관리 기준',
    body: '상담·교육·취업알선 등 제공 방식, 참여 안내, 결과물 보관, 만족도 확인 절차를 함께 점검합니다.',
    criteria: ['진로설계·취업알선·취·창업교육·복합제공 중 적합한 유형', '집체교육·개별상담·온라인·대면 등 운영 방식', '참여 대상자 선정과 안내·동의 절차', '상담일지·출석부·교육사진·만족도 조사 등 증빙자료'],
    materials: '기존 교육·상담 자료, 참여자 안내문, 개인정보 동의서, 증빙관리 양식',
  },
  {
    title: '파일럿 운영으로 확인할 현장 쟁점',
    body: '참여자 모집, 일정 운영, 상담 흐름, 결과 정리 방식이 실제 사업장에서 작동하는지 소규모로 확인합니다.',
    criteria: ['파일럿 참여자 모집 가능 여부와 적정 인원', '근무시간·교대근무를 고려한 일정 편성', '상담·교육 장소와 참여시간 확보 가능 여부', '참여자 의견·만족도 확인과 후속 보완 방식'],
    materials: '대상자 후보, 근무일정, 운영장소, 참여 안내계획, 만족도 조사양식',
  },
];
const outputItems = [
  ['운영 현황 진단', '대상자, 준비 수준, 내부 의사결정 필요사항을 구분합니다.', '현재 기업이 바로 실행할 수 있는 부분과 추가 정리가 필요한 부분을 나눠 이후 제도설계의 기준으로 삼습니다.'],
  ['제도화 실행안', '담당자 역할, 운영 절차, 참여자 안내, 파일럿 운영 흐름을 정리합니다.', '담당자가 실제로 사용할 수 있도록 실행 순서, 안내 문구, 일정 운영, 산출물 정리 방식을 포함합니다.'],
  ['최종 개선 과제', '파일럿 결과와 현장 의견을 바탕으로 후속 보완사항을 제시합니다.', '한 번의 컨설팅으로 끝내지 않고 다음 운영 주기에 반영할 개선 과제와 우선순위를 남깁니다.'],
];
---
<BaseLayout title="재취업지원서비스 기업컨설팅" description="기업이 재취업지원서비스를 자체 제도화하고 시행할 수 있도록 현황 진단, 운영체계 설계, 7단계 컨설팅과 파일럿 운영을 지원합니다." jsonLd={businessConsultingJsonLd}>
  <section class="ty-hero sub">
    <div class="ty-mark">기업컨설팅</div>
    <p class="ty-comment">기업의 자체 운영체계 설계</p>
    <h1 class="business-title">기업 안에서 작동하는<br />재취업지원서비스 체계를 설계합니다.</h1>
    <p class="ty-lead">기업이 재취업지원서비스를 자체적으로 시행할 수 있도록<br class="wide-break" /> 현황 진단부터 계획 수립, 파일럿 운영, 제도설계까지 지원합니다.</p>
    <div class="mobile-quick-card service" aria-label="기업컨설팅 모바일 핵심 안내">
      <span>기업 담당자 확인사항</span>
      <strong>제도 운영 전에 다음 항목을 확인하세요.</strong>
      <ul>
        <li>의무기업 여부와 대상자 발생 가능성 확인</li>
        <li>담당부서·내부 결재 흐름 정리</li>
        <li>파일럿 운영으로 현장 적용성 점검</li>
      </ul>
      <a href="/contact/">기업컨설팅 문의하기</a>
    </div>
  </section>

  <section class="ty-section">
    <div class="ty-section-head">
      <h2>기업의 제도화 준비를 확인합니다.</h2>
      <p>의무대상기업과 제도 도입·개선을 검토하는 기업의 운영 여건을 점검합니다. 각 항목에서 자세한 실무 기준을 확인할 수 있습니다.</p>
    </div>
    <div class="ty-list-grid info-grid hover-info-grid">
      {readinessItems.map(([title, detail]) => (
        <article class="step-popover-card readiness-popover-card" tabindex="0" aria-describedby={`readiness-${title}-detail`}>
          <strong>{title}</strong>
          <div class="step-popover readiness-popover" id={`readiness-${title}-detail`} role="tooltip">
            <strong>{title}</strong>
            <p>{detail}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="ty-section">
    <div class="ty-section-head">
      <h2>7단계로 제도화 가능성을 확인합니다.</h2>
      <p>기업컨설팅은 7단계로 진행됩니다. 파일럿 단계에서는 설계한 운영체계를 현장에 시범 적용하고 보완점을 확인합니다.</p>
    </div>
    <div class="ty-process-list seven">
      {steps.map(([num, title, body, detail]) => (
        <article class="step-popover-card" tabindex="0" aria-describedby={`step-${num}-detail`}>
          <span>{num}</span>
          <h3>{title}</h3>
          <p>{body}</p>
          <div class="step-popover" id={`step-${num}-detail`} role="tooltip">
            <strong>{title} 단계</strong>
            <p>{detail}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="ty-section">
    <div class="ty-section-head">
      <h2>기업 상황에 따라 컨설팅 유형이 달라집니다.</h2>
      <p>기초·전문·공동컨설팅은 기업의 시행 경험과 운영 여건에 따라 다르게 적용됩니다.</p>
    </div>
    <div class="ty-feature-row three info-grid">
      {supportTypes.map(([title, body, detail]) => (
        <article class="step-popover-card support-popover-card" tabindex="0" aria-describedby={`support-${title}-detail`}>
          <h3>{title}</h3>
          <p>{body}</p>
          <div class="step-popover support-popover" id={`support-${title}-detail`} role="tooltip">
            <strong>{title}</strong>
            <p>{detail}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="ty-section">
    <div class="ty-section-head">
      <p class="ty-comment">기업 담당자 확인사항</p>
      <h2>재취업지원서비스 운영체계를 만들기 전에 실무 기준을 정리합니다.</h2>
      <p>기업 담당자가 제도 운영 전에 확인해야 할 실무 항목입니다.</p>
    </div>
    <div class="ty-checks hover-checks">
      {practicalChecks.map(({ title, body, criteria, materials }) => (
        <article class="step-popover-card output-popover-card" tabindex="0" aria-describedby={`practical-${title}-detail`}>
          <strong>{title}</strong>
          <span>{body}</span>
          <div class="step-popover output-popover practical-detail-popover" id={`practical-${title}-detail`} role="tooltip">
            <strong>{title}</strong>
            <p class="popover-section-label">세부 확인 기준</p>
            <ul>
              {criteria.map((item) => <li>{item}</li>)}
            </ul>
            <p class="popover-materials"><strong>준비자료</strong><span>{materials}</span></p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="ty-section ty-note-panel">
    <div>
      <p class="ty-comment">정리 산출물</p>
      <h2>누구나 일관되게 운영할 수 있는 기준을 마련합니다.</h2>
    </div>
    <div class="ty-checks info-checks hover-checks">
      {outputItems.map(([title, body, detail]) => (
        <article class="step-popover-card output-popover-card" tabindex="0" aria-describedby={`output-${title}-detail`}>
          <strong>{title}</strong>
          <span>{body}</span>
          <div class="step-popover output-popover" id={`output-${title}-detail`} role="tooltip">
            <strong>{title}</strong>
            <p>{detail}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
