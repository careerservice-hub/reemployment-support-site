---
import BaseLayout from '../layouts/BaseLayout.astro';
const steps = [
  ['01', '착수', '기업 현황과 컨설팅 범위를 확인하고 진행 기준을 맞춥니다.'],
  ['02', '환경분석', '제도 운영 여건, 대상자 규모, 내부 준비 수준을 진단합니다.'],
  ['03', '계획수립', '기업 상황에 맞는 컨설팅 일정과 운영 방향을 정리합니다.'],
  ['04', '중간보고', '진단 결과와 설계 방향을 점검하고 보완 과제를 확인합니다.'],
  ['05', '파일럿운영', '설계한 서비스 흐름을 일부 대상자에게 시범 적용합니다.'],
  ['06', '제도설계', '기업이 자체 시행할 수 있는 운영체계와 절차를 구체화합니다.'],
  ['07', '최종보고', '실행 결과, 개선사항, 제도화 과제를 최종 정리합니다.'],
];
const supportTypes = [
  ['기초컨설팅', '시행 경험이 없거나 도입을 준비하는 기업의 인식 개선, 도입 체계, 운영 체계 구축을 지원합니다.'],
  ['전문컨설팅', '시행 경험이 있는 기업의 개선사항 진단, 전담인력 역량강화, 운영체계 강화, 성과관리를 점검합니다.'],
  ['공동컨설팅', '원·하청, 산업단지 등 공동 운영 여건에 맞춰 별도 기준과 모듈식 방식으로 조정합니다.'],
];
---
<BaseLayout title="기업컨설팅" description="기업이 재취업지원서비스를 자체 제도화하고 시행할 수 있도록 7단계 컨설팅과 파일럿 운영을 지원합니다.">
  <section class="ty-hero sub">
    <div class="ty-mark">기업컨설팅</div>
    <p class="ty-comment">대행 제공이 아니라 제도화 설계</p>
    <h1 class="business-title">기업 안에서 작동하는<br />재취업지원서비스 체계를 설계합니다.</h1>
    <p class="ty-lead">기업컨설팅은 재취업지원서비스를 대신 제공하는 과정이 아닙니다.<br class="wide-break" /> 기업이 자체적으로 시행할 수 있도록 진단, 계획, 파일럿, 제도설계까지 단계별로 정리합니다.</p>
  </section>

  <section class="ty-section">
    <div class="ty-section-head">
      <h2>기업의 제도화 준비를 확인합니다.</h2>
      <p>의무대상기업뿐 아니라 제도 도입·개선을 검토하는 기업도 현재 여건을 기준으로 운영 가능성을 점검합니다.</p>
    </div>
    <div class="ty-list-grid">
      <p>재취업지원서비스 도입 또는 개선을 검토하는 기업</p>
      <p>대상자 규모, 내부 역할, 운영 절차를 정리해야 하는 기업</p>
      <p>담당자 안내, 참여자 모집, 일정 운영 방식을 구체화하려는 기업</p>
      <p>파일럿 운영을 통해 현장 적용 가능성을 확인하려는 기업</p>
    </div>
  </section>

  <section class="ty-section">
    <div class="ty-section-head">
      <h2>7단계로 제도화 가능성을 확인합니다.</h2>
      <p>단일컨설팅은 리플릿 기준 7단계 흐름으로 진행됩니다. 파일럿 운영은 직접 제공 목적이 아니라 설계한 체계가 실제로 작동하는지 검증하는 단계입니다.</p>
    </div>
    <div class="ty-process-list seven">
      {steps.map(([num, title, body]) => (
        <article>
          <span>{num}</span>
          <h3>{title}</h3>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="ty-section">
    <div class="ty-section-head">
      <h2>기업 상황에 따라 컨설팅 유형이 달라집니다.</h2>
      <p>기초·전문·공동컨설팅은 기업의 시행 경험과 운영 여건에 따라 다르게 적용됩니다.</p>
    </div>
    <div class="ty-feature-row three">
      {supportTypes.map(([title, body]) => <article><h3>{title}</h3><p>{body}</p></article>)}
    </div>
  </section>

  <section class="ty-section ty-note-panel">
    <div>
      <p class="ty-comment">정리 산출물</p>
      <h2>기업이 계속 운영할 수 있는 기준을 남깁니다.</h2>
    </div>
    <div class="ty-checks">
      <p><strong>운영 현황 진단</strong><span>대상자, 준비 수준, 내부 의사결정 필요사항을 구분합니다.</span></p>
      <p><strong>제도화 실행안</strong><span>담당자 역할, 운영 절차, 참여자 안내, 파일럿 운영 흐름을 정리합니다.</span></p>
      <p><strong>최종 개선 과제</strong><span>파일럿 결과와 현장 의견을 바탕으로 후속 보완사항을 제시합니다.</span></p>
    </div>
  </section>
</BaseLayout>
