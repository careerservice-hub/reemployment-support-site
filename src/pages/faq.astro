---
import BaseLayout from '../layouts/BaseLayout.astro';

const consultingFaqs = [
  {
    q: '재취업지원서비스 기업컨설팅은 무엇을 지원하나요?',
    a: '기업이 재취업지원서비스를 자체적으로 제도화하고 시행할 수 있도록 현황 진단, 운영체계 설계, 파일럿 운영, 개선과제 정리를 지원합니다.',
  },
  {
    q: '기업컨설팅에서는 무엇을 설계하나요?',
    a: '기업이 재취업지원서비스를 자체 운영할 수 있도록 시행체계를 설계합니다. 파일럿을 통해 현장 적용 가능성도 점검합니다.',
  },
  {
    q: '어떤 기업이 기업컨설팅을 검토할 수 있나요?',
    a: '재취업지원서비스 의무대상기업, 제도 도입을 준비하는 기업, 기존 운영체계를 개선하려는 기업, 원·하청 또는 산업단지 단위 공동 운영을 검토하는 기업이 상담을 요청할 수 있습니다.',
  },
  {
    q: '이미 재취업지원서비스를 운영 중인 기업도 컨설팅이 필요한가요?',
    a: '필요할 수 있습니다. 기존 운영 경험이 있는 기업은 참여율, 안내체계, 담당자 역할, 산출물 관리, 성과관리 기준을 점검해 개선과제를 정리할 수 있습니다.',
  },
  {
    q: '퇴직예정자가 아직 없어도 기업컨설팅을 검토할 수 있나요?',
    a: '제도 도입이나 운영체계 사전 준비가 필요한 기업은 상담을 통해 가능성을 확인할 수 있습니다. 대상자 발생 이후에만 준비하면 안내와 운영이 늦어질 수 있어 사전 점검이 도움이 됩니다.',
  },
  {
    q: '기업컨설팅 신청 전에 무엇을 준비해야 하나요?',
    a: '퇴직예정자 발생 가능성, 50세 이상 근로자 현황, 담당 부서, 기존 제도 운영 여부, 내부 의사결정 일정, 희망 진행 시기를 먼저 확인하면 상담이 빠르게 진행됩니다.',
  },
  {
    q: '기업 담당자는 상담 전에 어떤 내부 정보를 확인하면 좋나요?',
    a: '대상자 규모, 퇴직예정자 발생 시점, 담당 부서, 내부 보고 일정, 노사협의 또는 인사부서 협의 필요성, 기존 교육·전직지원 프로그램 운영 여부를 확인하면 좋습니다.',
  },
  {
    q: '기초컨설팅과 전문컨설팅은 어떻게 다른가요?',
    a: '기초컨설팅은 제도 도입 경험이 적은 기업의 기본 운영체계 구축에 초점을 둡니다. 전문컨설팅은 기존 운영 경험이 있는 기업의 개선사항 진단, 전담인력 역량강화, 성과관리 고도화에 초점을 둡니다.',
  },
  {
    q: '파일럿 운영은 왜 필요한가요?',
    a: '파일럿 운영은 설계한 안내문, 상담 흐름, 대상자 참여 방식과 산출물 정리 방식을 실제 사업장에 적용해 보완점을 확인하는 단계입니다.',
  },
  {
    q: '파일럿 운영 결과는 최종 제도설계에 어떻게 반영되나요?',
    a: '참여자 반응, 담당자 의견, 상담 흐름, 안내문 이해도, 결과물 작성 수준, 일정 운영상 문제를 검토해 기업별 운영기준과 개선과제에 반영합니다.',
  },
  {
    q: '기업컨설팅 결과물은 무엇인가요?',
    a: '기업 현황 진단, 운영체계 설계안, 담당자 역할, 참여자 안내 방식, 파일럿 결과, 개선과제, 후속 실행 방향 등이 기업별 상황에 맞게 정리됩니다.',
  },
  {
    q: '기업컨설팅 결과는 내부 보고자료로 활용할 수 있나요?',
    a: '활용할 수 있습니다. 현황 진단, 운영체계, 파일럿 결과와 개선과제를 내부 보고와 다음 운영계획에 활용할 수 있도록 정리합니다.',
  },
  {
    q: '상담신청 후에는 어떻게 진행되나요?',
    a: '담당자가 신청 주체와 대상 여부, 일정, 준비자료를 확인한 뒤 진행 가능 여부를 안내합니다.',
  },
  {
    q: '재취업지원서비스 의무기업은 무엇을 먼저 확인해야 하나요?',
    a: '재취업지원서비스 의무기업은 대상자 발생 가능성, 퇴직예정자 안내 시점, 서비스 제공 방식, 담당부서 역할, 증빙관리 기준을 먼저 확인해야 합니다. 기업컨설팅에서는 이 항목을 기업 여건에 맞게 점검합니다.',
  },
  {
    q: '재취업지원서비스를 처음 도입하는 기업은 어디서부터 준비해야 하나요?',
    a: '처음 도입하는 기업은 50세 이상 근로자 현황, 퇴직예정자 발생 가능성, 담당부서, 내부 안내 절차, 외부 상담·교육 연계 가능성을 먼저 정리하는 것이 좋습니다.',
  },
  {
    q: '인사담당자가 재취업지원서비스 운영체계를 만들 때 중요한 것은 무엇인가요?',
    a: '인사담당자는 대상자 선정, 사전 안내, 상담·교육 일정, 참여시간 확보, 결과물 보관, 만족도 확인, 사후관리 절차를 하나의 운영체계로 정리해야 합니다.',
  },
];

const careerFaqs = [
  {
    q: '커리어플래닝서비스는 어떤 서비스인가요?',
    a: '중장년 재직자의 직무경험, 보유역량, 관심 분야, 향후 경력방향을 점검하고 경력설계와 실행계획을 상담 중심으로 정리하는 서비스입니다.',
  },
  {
    q: '커리어플래닝서비스에서는 어떤 도움을 받을 수 있나요?',
    a: '경력진단과 경력설계를 통해 직무전환, 계속근로 또는 구직 준비 방향을 정리합니다.',
  },
  {
    q: '커리어플래닝서비스는 누가 신청할 수 있나요?',
    a: '기본적으로 중장년 재직자를 대상으로 하며, 사업장 규모와 지원 기준은 해당 연도 사업 안내와 예산 상황에 따라 확인이 필요합니다. 상담 단계에서 대상 여부를 먼저 확인합니다.',
  },
  {
    q: '퇴직예정자가 아니어도 신청할 수 있나요?',
    a: '커리어플래닝서비스는 재직 중 경력설계 성격이 있으므로 퇴직예정자 여부만으로 판단하지 않습니다. 재직 여부, 연령, 사업 기준, 운영 가능 일정 등을 함께 확인합니다.',
  },
  {
    q: '개인도 커리어플래닝서비스를 신청할 수 있나요?',
    a: '개인 신청 가능 여부는 운영 기준과 예산 상황에 따라 달라질 수 있습니다. 홈페이지의 문의 또는 신청 안내를 통해 대상 여부와 제출 방법을 먼저 확인하는 것이 좋습니다.',
  },
  {
    q: '기업 단위로도 커리어플래닝서비스를 운영할 수 있나요?',
    a: '기업 단위 신청도 가능합니다. 참여 예상 인원과 희망 일정을 알려주시면 대상 조건과 운영 일정을 안내합니다.',
  },
  {
    q: '상담에서는 어떤 내용을 다루나요?',
    a: '현재까지의 직무경험, 강점, 관심 분야, 역할 변화 가능성, 직무전환 또는 계속근로 방향, 교육·자격·구직 준비 등 후속 실행과제를 다룹니다.',
  },
  {
    q: '상담에서는 어떤 경력 방향을 다루나요?',
    a: '계속근로, 직무전환, 역량개발, 전직 준비 등 개인 상황에 맞는 방향을 함께 정리합니다.',
  },
  {
    q: '상담 결과는 어떤 형태로 정리되나요?',
    a: '상담 결과는 참여자의 경력 흐름, 보유역량, 향후 목표, 실행 과제와 후속 준비사항을 중심으로 정리됩니다. 일과 직무, 앞으로의 경력 방향에 초점을 둡니다.',
  },
  {
    q: '경력설계서에는 어떤 내용이 들어가나요?',
    a: '직무경험, 주요 강점, 보유역량, 관심 분야, 향후 경력방향, 역량 보완 과제, 실행계획, 후속 준비사항 등이 개인별 상담 결과에 맞게 정리됩니다.',
  },
  {
    q: '상담 결과는 회사에 공유되나요?',
    a: '개인정보와 상담 세부내용은 목적 범위 안에서 관리되어야 합니다. 기업 단위 운영의 경우에도 공유 범위와 방식은 사전 안내와 동의 기준에 따라 구분하는 것이 원칙입니다.',
  },
  {
    q: '신청 전에 어떤 정보를 확인하면 좋나요?',
    a: '성명, 연락처, 재직 여부, 희망 상담 일정, 관심 있는 경력 방향, 신청 양식과 개인정보 동의서 작성 가능 여부를 확인하면 접수와 일정 조율이 수월합니다.',
  },
  {
    q: '주민등록번호나 민감정보를 입력해야 하나요?',
    a: '상담신청에는 주민등록번호, 건강정보, 급여자료, 내부 인사자료 등 민감정보를 입력하지 마세요. 상담과 연락에 필요한 최소 정보만 남겨 주세요.',
  },
  {
    q: '40대와 50대 재직자도 경력설계 상담을 받을 수 있나요?',
    a: '사업 기준과 운영 상황에 따라 중장년 재직자는 경력진단과 경력설계 상담을 검토할 수 있습니다. 상담에서는 직무경험, 보유역량, 직무전환 가능성, 계속근로 방향, 재취업 준비사항을 확인합니다.',
  },
  {
    q: '퇴직 전 경력설계 상담에서는 무엇을 정리하나요?',
    a: '퇴직 전 경력설계 상담에서는 현재 직무경험, 강점, 보유자격, 희망 근무조건, 직무전환 가능성, 재취업 준비 정도, 향후 실행계획을 일·직무 중심으로 정리합니다.',
  },
  {
    q: '중장년 재직자가 직무전환을 준비할 때 어떤 도움이 되나요?',
    a: '기존 업무경험을 다른 기업과 직무에서도 쉽게 이해할 수 있도록 정리하고, 필요한 교육·자격과 구직정보를 찾는 방법을 확인할 수 있습니다.',
  },
];

const commonFaqs = [
  {
    q: '경력지원서비스란 무엇인가요?',
    a: '경력지원서비스는 재직자의 경력진단과 경력설계부터 퇴직예정자의 경력전환과 재취업 준비까지 연결하여 살펴보는 지원 개념입니다.',
  },
  {
    q: '경력지원서비스는 재취업지원서비스와 다른 정부사업인가요?',
    a: '이 홈페이지에서 사용하는 경력지원서비스는 별도의 정부사업이 확정되었다는 의미가 아닙니다. 현재 공식 사업 안내는 재취업지원서비스 시행지원을 기준으로 하며, K·JOBS가 서비스의 목적과 이용자 효용을 설명하기 위해 함께 사용하는 표현입니다.',
  },
  {
    q: '재취업지원서비스 시행지원과 경력지원서비스는 어떤 관계인가요?',
    a: '재취업지원서비스 시행지원은 기업의 시행체계 구축과 근로자의 경력전환 준비를 지원합니다. 경력지원서비스는 이 과정을 재직 단계의 경력설계부터 퇴직 이후의 전환 준비까지 연결해 이해하도록 돕는 설명 개념입니다.',
  },
  {
    q: '상담신청을 하면 언제 연락을 받을 수 있나요?',
    a: '담당자가 상담 유형, 연락처와 문의 내용을 확인하는 대로 연락드립니다.',
  },
  {
    q: '상담신청 후 최종 진행 여부는 언제 안내되나요?',
    a: '담당자가 대상 여부, 일정, 준비자료와 사업 기준을 확인한 뒤 최종 진행 여부를 안내합니다.',
  },
  {
    q: '상담신청에 어떤 정보를 남기면 되나요?',
    a: '성명 또는 담당자명, 기업명, 연락처, 이메일, 상담 유형, 희망 내용을 중심으로 남기면 됩니다. 상담 단계에서는 필요한 최소 정보만 입력하는 것이 원칙입니다.',
  },
  {
    q: '민감정보를 입력하면 어떻게 해야 하나요?',
    a: '주민등록번호, 건강정보, 급여자료, 내부 인사자료, 퇴직자 명단 등은 입력하지 않아야 합니다. 이미 입력한 경우에는 담당자 안내에 따라 필요한 범위에서 정정 또는 삭제 요청을 할 수 있습니다.',
  },
  {
    q: '비용이 발생하나요?',
    a: '재취업지원서비스 시행지원 사업 기준에 따라 기업과 참여자의 비용 부담을 낮추는 방식으로 운영됩니다. 세부 지원 범위와 적용 가능 여부는 해당 연도 사업 안내와 상담을 통해 확인합니다.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [...consultingFaqs, ...careerFaqs, ...commonFaqs].map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};
---
<BaseLayout title="FAQ" description="경력지원서비스, 재취업지원서비스 기업컨설팅과 커리어플래닝서비스에 대해 자주 묻는 질문을 안내합니다." jsonLd={faqJsonLd}>
  <section class="ty-hero sub">
    <div class="ty-mark">FAQ</div>
    <p class="ty-comment">경력지원서비스 · 기업컨설팅 · 커리어플래닝서비스</p>
    <h1>자주 묻는 질문을 서비스별로 확인합니다.</h1>
    <p class="ty-lead">기업 담당자와 개인 신청자가 가장 먼저 확인하는 질문을 나누어 정리했습니다. 상담 전 대상 여부, 준비자료, 진행 방식을 빠르게 확인할 수 있습니다.</p>
  </section>

  <section class="ty-section faq-section" aria-labelledby="consulting-faq-title">
    <div class="ty-section-head">
      <p class="ty-comment">기업 담당자용</p>
      <h2 id="consulting-faq-title">기업컨설팅 FAQ</h2>
      <p>재취업지원서비스를 기업 안에서 제도화하고 운영체계를 준비할 때 자주 묻는 질문입니다.</p>
    </div>
    <div class="faq-list">
      {consultingFaqs.map((item) => (
        <details class="faq-item">
          <summary>{item.q}</summary>
          <p>{item.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="ty-section faq-section" aria-labelledby="career-faq-title">
    <div class="ty-section-head">
      <p class="ty-comment">개인·기업 신청 공통</p>
      <h2 id="career-faq-title">커리어플래닝서비스 FAQ</h2>
      <p>중장년 재직자의 경력진단과 경력설계 상담을 검토할 때 자주 묻는 질문입니다.</p>
    </div>
    <div class="faq-list">
      {careerFaqs.map((item) => (
        <details class="faq-item">
          <summary>{item.q}</summary>
          <p>{item.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="ty-section faq-section" aria-labelledby="common-faq-title">
    <div class="ty-section-head">
      <p class="ty-comment">상담신청 공통 확인</p>
      <h2 id="common-faq-title">공통 FAQ</h2>
      <p>경력지원서비스 명칭, 상담신청, 개인정보 입력, 연락 방식 등 공통으로 확인할 질문입니다.</p>
    </div>
    <div class="faq-list">
      {commonFaqs.map((item) => (
        <details class="faq-item">
          <summary>{item.q}</summary>
          <p>{item.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="ty-section faq-note" aria-label="상담 전 확인">
    <div class="ty-note-panel">
      <h2>원하는 답을 찾지 못했다면 상담신청으로 확인하세요.</h2>
      <p>궁금한 내용을 남겨 주시면 대상 여부와 신청 절차를 안내해 드립니다. 주민등록번호 등 민감정보는 입력하지 마세요.</p>
      <a class="ty-inline-link" href="/contact/">문의 페이지로 이동</a>
    </div>
  </section>
</BaseLayout>
