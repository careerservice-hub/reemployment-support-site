---
import BaseLayout from '../layouts/BaseLayout.astro';

const principles = [
  {
    title: '기준 정확성',
    body: '확정되지 않은 내용을 단정하지 않고 확인 가능한 기준과 절차를 안내합니다.',
    detailTitle: '공식 기준을 먼저 확인',
    detail: '노사발전재단·고용노동부 기준을 중심으로 대상 여부, 신청 제한, 제출자료, 일정 조건을 확인합니다. 불확실한 항목은 확정 표현으로 안내하지 않고 확인 필요사항으로 분리합니다.',
  },
  {
    title: '실행 가능성',
    body: '기업 담당자가 내부 설명과 일정 조율에 쓸 수 있도록 준비사항을 구체화합니다.',
    detailTitle: '현장에서 바로 쓸 수 있게 정리',
    detail: '기업 담당자가 내부 보고, 참여자 안내, 일정 조율에 사용할 수 있도록 준비자료와 진행순서를 짧고 명확하게 정리합니다.',
  },
  {
    title: '이해도 향상',
    body: '중장년 재직자가 경력 방향을 쉽게 이해하도록 상담 언어를 정돈합니다.',
    detailTitle: '참여자 관점의 상담 언어',
    detail: '제도 설명에 머무르지 않고 참여자가 자신의 경력, 직무경험, 전환 가능성을 이해할 수 있도록 상담 결과와 후속 행동을 쉬운 언어로 정리합니다.',
  },
];

const supportScopes = [
  {
    title: '안내',
    body: '서비스 목적, 대상 여부, 신청 전 확인사항을 이해하기 쉬운 순서로 설명합니다.',
    detailTitle: '처음 이해해야 할 내용을 정리',
    detail: '기업과 참여자가 혼동하기 쉬운 서비스 목적, 신청 대상, 준비서류, 진행 전 확인사항을 먼저 정리해 시작 단계의 부담을 줄입니다.',
  },
  {
    title: '조율',
    body: '기업 담당자, 참여자, 상담 진행 일정을 맞춰 무리 없는 진행 흐름을 만듭니다.',
    detailTitle: '담당자와 참여자 사이의 운영 흐름 조정',
    detail: '기업 내부 일정, 참여자 가능 시간, 상담 운영 방식이 어긋나지 않도록 진행 순서와 커뮤니케이션 기준을 맞춥니다.',
  },
  {
    title: '정리',
    body: '상담 결과와 후속 과제를 남겨 다음 행동을 확인할 수 있게 합니다.',
    detailTitle: '결과가 다음 행동으로 이어지게 정리',
    detail: '상담에서 확인된 경력 방향, 보완 과제, 후속지원 필요사항을 남겨 기업과 참여자가 이후 행동을 확인할 수 있게 합니다.',
  },
];
---
<BaseLayout title="K·JOBS 지원 방식">
  <section class="ty-hero sub">
    <div class="ty-mark">K·JOBS 지원 방식</div>
    <p class="ty-comment">기준은 정확하게, 실행은 쉽게</p>
    <h1>기업과 참여자를 함께 봅니다.</h1>
    <p class="ty-lead">공식 기준은 정확하게 확인하고, 현장에서는 기업 담당자와 참여자가 이해하기 쉬운 언어와 절차로 풀어냅니다.</p>
  </section>

  <section class="ty-section ty-editorial">
    <p>재취업지원서비스는 기업의 제도 운영과 근로자의 경력 준비가 함께 맞물려야 합니다.</p>
    <p>케이잡스는 기준, 일정, 상담, 결과 정리를 하나의 흐름으로 연결합니다.</p>
  </section>

  <section class="ty-section">
    <div class="ty-section-head">
      <h2>세 가지 지원 원칙</h2>
      <p>케이잡스 관점에서 세 가지를 분명히 합니다.</p>
    </div>
    <div class="ty-feature-row three info-grid">
      {principles.map((item) => (
        <article class="step-popover-card support-popover-card" tabindex="0" aria-describedby={`approach-principle-${item.title}-detail`}>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
          <div class="step-popover support-popover" id={`approach-principle-${item.title}-detail`} role="tooltip">
            <strong>{item.detailTitle}</strong>
            <p>{item.detail}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="ty-section ty-note-panel">
    <div>
      <p class="ty-comment">지원 범위</p>
      <h2>안내, 조율, 정리를 함께 수행합니다.</h2>
    </div>
    <div class="ty-checks hover-checks">
      {supportScopes.map((item) => (
        <article class="step-popover-card output-popover-card" tabindex="0" aria-describedby={`approach-scope-${item.title}-detail`}>
          <strong>{item.title}</strong>
          <span>{item.body}</span>
          <div class="step-popover output-popover" id={`approach-scope-${item.title}-detail`} role="tooltip">
            <strong>{item.detailTitle}</strong>
            <p>{item.detail}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
