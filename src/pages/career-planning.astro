---
import BaseLayout from '../layouts/BaseLayout.astro';
import { careerPlanningJsonLd } from '../data/structuredData.js';
const flow = [
  {
    title: '경력진단',
    body: '직무경험, 강점, 관심 분야를 점검합니다.',
    detailTitle: '무엇을 확인하나요?',
    detail: '현재까지 수행한 직무, 역할 변화, 주요 성과, 강점과 관심 분야를 정리해 경력의 흐름을 다시 확인합니다.',
  },
  {
    title: '역량 점검',
    body: '현재 보유역량과 향후 필요한 역량을 비교합니다.',
    detailTitle: '어떤 기준으로 보나요?',
    detail: '현재 직무에서 활용 가능한 역량과 향후 직무전환·계속근로·전직 준비에 필요한 역량을 비교해 보완 과제를 찾습니다.',
  },
  {
    title: '목표 설정',
    body: '역할 변화와 개인 목표를 연결해 방향을 구체화합니다.',
    detailTitle: '어떤 방향을 정하나요?',
    detail: '계속근로, 직무전환, 재취업 준비, 교육 참여 등 개인 상황에 맞는 경력 방향과 우선순위를 구체화합니다.',
  },
  {
    title: '실행계획',
    body: '교육, 직무, 전직준비 등 실천 과제를 정리합니다.',
    detailTitle: '결과물은 무엇인가요?',
    detail: '상담 결과를 바탕으로 교육·자격·직무경험 정리·구직 준비 등 바로 실행할 수 있는 후속 과제를 정리합니다.',
  },
];
const applicationSteps = [
  {
    title: '양식 다운로드',
    body: '필요한 양식을 내려받고 사용 가능한 파일 형식을 선택합니다.',
    detailTitle: '파일은 어디서 받나요?',
    detail: '신청서와 개인정보 동의서는 각각 HWP와 PDF 형식으로 제공합니다. 신청자는 사용 가능한 프로그램에 맞춰 한 가지 형식을 선택하면 됩니다.',
  },
  {
    title: '작성·서명',
    body: '신청서와 개인정보 동의서를 작성하고 필요한 서명란에 서명합니다.',
    detailTitle: '무엇을 확인해야 하나요?',
    detail: '성명, 연락처, 희망 일정, 서명란 누락 여부를 확인합니다. 서명이 빠지면 접수 보완을 요청할 수 있습니다.',
  },
  {
    title: '이메일 제출',
    body: '양식과 재직증명서를 이메일로 보냅니다.',
    detailTitle: '무엇을 함께 제출하나요?',
    detail: '작성·서명한 신청서, 개인정보 동의서, 재직증명서를 함께 제출합니다. PDF 제출을 권장하며, 사진 파일은 글자와 서명이 선명하게 보이도록 촬영합니다.',
  },
  {
    title: '접수 확인',
    body: '접수 후 대상 여부와 진행 일정을 안내합니다.',
    detailTitle: '접수 후에는 어떻게 진행되나요?',
    detail: '신청서를 접수한 뒤 참여 대상 여부와 진행 일정, 보완할 사항을 안내합니다.',
  },
];
---
<BaseLayout title="커리어플래닝서비스" description="중장년 재직자의 직무경험과 보유역량을 점검하고 향후 경력방향, 직무전환, 계속근로, 재취업 준비를 상담 중심으로 지원합니다." jsonLd={careerPlanningJsonLd}>
  <section class="ty-hero sub">
    <div class="ty-mark">커리어플래닝서비스</div>
    <p class="ty-comment">경험을 다음 경력 방향으로</p>
    <h1>경력을 다시 읽고, 다음을 씁니다.</h1>
    <p class="ty-lead">중장년 재직자의 직무경험과 강점을 점검하고 앞으로의 역할 변화와 경력목표를 정리합니다.</p>
    <div class="mobile-quick-card service" aria-label="커리어플래닝서비스 모바일 핵심 안내">
      <span>신청 전 확인사항</span>
      <strong>다음 세 가지를 준비해 주세요.</strong>
      <ul>
        <li>중장년 재직자 여부와 상담 가능 일정</li>
        <li>신청서·개인정보 동의서 작성 가능 여부</li>
        <li>재직증명서 등 재직 확인 서류 준비</li>
      </ul>
      <a href="#career-application-title">양식 다운로드로 이동</a>
    </div>
  </section>

  <section class="ty-section ty-video" aria-labelledby="career-video-title">
    <div class="ty-section-head left">
      <h2 id="career-video-title">공식 안내 영상</h2>
      <p>고용노동부 커리어플래닝서비스 홍보영상으로 서비스의 취지와 운영 방식을 먼저 확인할 수 있습니다.</p>
    </div>
    <div class="video-frame" aria-label="고용노동부 커리어플래닝서비스 홍보영상">
      <iframe src="https://www.youtube.com/embed/lytvNDvbWyo?rel=0" title="고용노동부 커리어플래닝서비스 홍보영상" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
      <a class="video-direct-link" href="https://youtu.be/lytvNDvbWyo" target="_blank" rel="noopener noreferrer">영상이 보이지 않으면 YouTube에서 바로 보기</a>
    </div>
  </section>

  <section class="ty-section">
    <div class="ty-section-head">
      <h2>경력진단부터 실행계획까지</h2>
      <p>직무경험과 역량을 살펴보고 다음 경력 방향과 실천 과제를 정합니다.</p>
    </div>
    <div class="ty-feature-row four career-popover-row">
      {flow.map((item) => (
        <article class="step-popover-card career-step-card" tabindex="0">
          <h3>{item.title}</h3>
          <p>{item.body}</p>
          <div class="step-popover career-popover" role="tooltip">
            <strong>{item.detailTitle}</strong>
            <p>{item.detail}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="ty-section application-download-section" aria-labelledby="career-application-title">
    <div class="ty-section-head">
      <p class="ty-comment">개인 신청 안내</p>
      <h2 id="career-application-title">양식을 내려받아 작성한 뒤 이메일로 제출합니다.</h2>
      <p>개인 신청자는 신청서와 개인정보 동의서를 작성·서명해 이메일로 제출해 주세요.</p>
    </div>
    <div class="download-panel">
      <div class="download-copy">
        <h3>제출 흐름</h3>
        <div class="application-step-grid" aria-label="커리어플래닝서비스 신청 제출 흐름">
          {applicationSteps.map((item) => (
            <article class="step-popover-card application-step-card" tabindex="0">
              <strong>{item.title}</strong>
              <span>{item.body}</span>
              <div class="step-popover application-flow-popover" role="tooltip">
                <strong>{item.detailTitle}</strong>
                <p>{item.detail}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
      <div class="download-files" aria-label="커리어플래닝서비스 신청 양식 다운로드 영역">
        <article class="download-card grouped-download-card">
          <span>필수 양식 1</span>
          <strong>커리어플래닝서비스 신청서</strong>
          <p>사용 환경에 맞는 파일 형식으로 내려받아 작성해 주세요.</p>
          <div class="same-form-choice" aria-label="커리어플래닝서비스 신청서 파일 형식 선택">
            <b>파일 형식 선택</b>
            <div class="download-actions">
              <a href="/downloads/career-planning-application.hwp" download>HWP로 받기</a>
              <a href="/downloads/career-planning-application.pdf" download>PDF로 받기</a>
            </div>
          </div>
        </article>
        <article class="download-card grouped-download-card">
          <span>필수 양식 2</span>
          <strong>개인정보 수집·이용·제공 및 고유식별정보 처리 동의서</strong>
          <p>사용 환경에 맞는 파일 형식으로 내려받아 작성해 주세요.</p>
          <div class="same-form-choice" aria-label="개인정보 동의서 파일 형식 선택">
            <b>파일 형식 선택</b>
            <div class="download-actions">
              <a href="/downloads/privacy-consent-form.hwp" download>HWP로 받기</a>
              <a href="/downloads/privacy-consent-form.pdf" download>PDF로 받기</a>
            </div>
          </div>
        </article>
        <article class="download-card grouped-download-card evidence-download-card">
          <span>필수 양식 3</span>
          <strong>재직 증빙</strong>
          <p>신청일 기준 재직 중임을 확인할 수 있는 서류를 함께 제출해 주세요.</p>
          <div class="same-form-choice evidence-note" aria-label="재직 증빙 제출 안내">
            <b>제출 가능 서류 예시</b>
            <ul>
              <li>재직증명서</li>
              <li>건강보험 자격득실확인서</li>
              <li>4대보험 가입확인서 또는 회사 발급 재직확인 서류</li>
            </ul>
          </div>
        </article>
      </div>
    </div>
    <div class="submission-note">
      <p><strong>제출서류</strong><span>신청서, 개인정보 동의서, 재직증명서</span></p>
      <p><strong>제출 이메일</strong><span>h.douze@kjobs.co.kr</span></p>
      <p><strong>파일명 권장</strong><span>커리어플래닝서비스_신청서_성명_휴대폰뒤4자리</span></p>
      <p><strong>문의</strong><span>02-797-5659 / 010-5747-8286</span></p>
    </div>
  </section>

  <section class="ty-section ty-note-panel">
    <div>
      <p class="ty-comment">기대 효과</p>
      <h2>참여자와 기업이 기대할 수 있는 변화</h2>
    </div>
    <div class="ty-checks">
      <p><strong>참여자</strong><span>자신의 경력과 강점을 객관적으로 이해하고 다음 경력 방향을 준비합니다.</span></p>
      <p><strong>기업</strong><span>중장년 재직자의 역량 활용과 직무 전환 가능성을 점검할 수 있습니다.</span></p>
      <p><strong>후속 지원</strong><span>상담 결과와 준비사항을 정리해 다음 행동으로 이어지도록 돕습니다.</span></p>
    </div>
  </section>
</BaseLayout>
