---
import BaseLayout from '../layouts/BaseLayout.astro';
const steps = [
  { title: '문의 및 대상 확인', body: '기업명, 참여 희망 서비스, 담당자 정보를 기준으로 상담 가능 범위와 대상 여부를 확인합니다.' },
  { title: '신청 방식 안내', body: '서비스 유형에 맞는 신청 흐름, 준비 자료, 내부 확인사항을 정리해 안내합니다.' },
  { title: '기업/개인 현황 파악', body: '기업의 운영 여건과 참여자의 경력 상황을 확인해 진행 방식을 구체화합니다.' },
  { title: '일정 조율', body: '담당자와 참여자의 일정을 고려해 컨설팅 또는 상담 진행 일정을 조율합니다.' },
  { title: '컨설팅 또는 상담 진행', body: '기업컨설팅은 운영체계 중심으로, 커리어플래닝서비스는 개인별 경력설계 중심으로 진행합니다.' },
  { title: '결과 정리 및 후속 안내', body: '진행 결과, 실행 과제, 이후 준비사항을 정리해 다음 행동으로 이어지도록 안내합니다.' },
];
---
<BaseLayout title="진행 절차">
  <section class="page-hero section">
    <span class="eyebrow">Process</span>
    <h1>신청 전 확인부터 결과 정리까지 단계별로 안내합니다.</h1>
    <p>서비스 유형과 신청 주체에 따라 세부 절차는 달라질 수 있습니다. 케이잡스는 대상 여부와 준비사항을 먼저 확인한 뒤, 기업과 개인에게 필요한 진행 방식을 안내합니다.</p>
  </section>
  <section class="timeline section" aria-label="진행 절차">
    {steps.map((step, index) => <article><span>{String(index + 1).padStart(2, '0')}</span><h2>{step.title}</h2><p>{step.body}</p></article>)}
  </section>
</BaseLayout>
