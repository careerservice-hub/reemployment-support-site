---
import BaseLayout from '../layouts/BaseLayout.astro';
const steps = ['문의 및 대상 확인', '신청 방식 안내', '기업/개인 현황 파악', '일정 조율', '컨설팅 또는 상담 진행', '결과 정리 및 후속지원 안내'];
---
<BaseLayout title="진행 절차">
  <section class="page-hero section">
    <span class="eyebrow">Process</span>
    <h1>신청 전 확인부터 결과 정리까지 단계별로 안내합니다.</h1>
    <p>서비스 유형과 신청 주체에 따라 세부 절차는 달라질 수 있습니다. 케이잡스는 대상 여부와 준비사항을 먼저 확인한 뒤, 기업과 개인에게 필요한 진행 방식을 안내합니다.</p>
  </section>
  <section class="timeline section">
    {steps.map((step, index) => <article><span>{String(index + 1).padStart(2, '0')}</span><h2>{step}</h2></article>)}
  </section>
</BaseLayout>
