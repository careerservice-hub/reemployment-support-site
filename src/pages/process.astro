---
import BaseLayout from '../layouts/BaseLayout.astro';
const steps = [
  ['대상 확인', '기업명, 희망 서비스, 담당자 정보를 기준으로 가능 범위를 확인합니다.'],
  ['신청 안내', '서비스 유형에 맞는 신청 흐름과 준비 자료를 정리합니다.'],
  ['현황 파악', '기업 여건과 참여자 상황을 확인해 진행 방식을 구체화합니다.'],
  ['일정 조율', '담당자와 참여자의 일정을 고려해 진행 일정을 맞춥니다.'],
  ['상담 진행', '기업컨설팅은 운영체계 중심으로, 커리어플래닝서비스는 경력설계 중심으로 진행합니다.'],
  ['결과 정리', '진행 결과와 실행 과제를 정리하고 다음 준비사항을 안내합니다.'],
];
---
<BaseLayout title="진행 절차">
  <section class="ty-hero sub">
    <div class="ty-mark">진행 절차</div>
    <p class="ty-comment">/* 문의에서 결과까지 */</p>
    <h1>확인하고, 맞추고, 정리합니다.</h1>
    <p class="ty-lead">서비스 유형과 신청 주체에 따라 세부 절차는 달라질 수 있습니다. 먼저 대상 여부와 준비사항을 확인합니다.</p>
  </section>

  <section class="ty-section">
    <div class="ty-section-head">
      <h2>One clear process</h2>
      <p>진행 과정은 여섯 단계로 단순화해 안내합니다.</p>
    </div>
    <div class="ty-process-list" aria-label="진행 절차">
      {steps.map(([title, body], index) => <article><span>{String(index + 1).padStart(2, '0')}</span><h3>{title}</h3><p>{body}</p></article>)}
    </div>
  </section>
</BaseLayout>
