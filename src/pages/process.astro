---
import BaseLayout from '../layouts/BaseLayout.astro';
const steps = [
  { title: '대상 확인', body: '기업명, 희망 서비스, 담당자 정보를 기준으로 대상 여부를 확인합니다.' },
  { title: '신청 안내', body: '서비스 유형에 맞는 신청 흐름과 준비 자료를 정리합니다.' },
  { title: '현황 파악', body: '기업 여건과 참여자 상황을 확인해 진행 방식을 구체화합니다.' },
  { title: '일정 조율', body: '담당자와 참여자의 일정을 고려해 컨설팅 또는 상담 진행 일정을 조율합니다.' },
  { title: '상담 진행', body: '기업컨설팅은 운영체계 중심으로 진행합니다. 커리어플래닝서비스는 개인별 경력설계를 다룹니다.' },
  { title: '결과 정리', body: '진행 결과와 실행 과제를 정리합니다. 이후 준비사항을 안내합니다.' },
];
---
<BaseLayout title="진행 절차">
  <section class="page-hero section">
    <span class="eyebrow">진행 절차</span>
    <h1>확인부터 결과 정리까지 단계별로 안내합니다.</h1>
    <p>서비스 유형과 신청 주체에 따라 세부 절차는 달라질 수 있습니다. 케이잡스는 대상 여부와 준비사항을 먼저 확인합니다.</p>
  </section>
  <section class="timeline section" aria-label="진행 절차">
    {steps.map((step, index) => <article><span>{String(index + 1).padStart(2, '0')}</span><h2>{step.title}</h2><p>{step.body}</p></article>)}
  </section>
</BaseLayout>
