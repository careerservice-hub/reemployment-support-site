---
import BaseLayout from '../layouts/BaseLayout.astro';
const steps = [
  [
    '문의 접수',
    '기업 또는 개인의 문의 내용을 확인하고, 필요한 지원 유형을 먼저 구분합니다.',
    '기업컨설팅, 커리어플래닝서비스, 개인 신청 문의가 섞이지 않도록 신청 주체와 희망 내용을 먼저 확인합니다. 이후 안내할 기준, 준비자료, 담당 연락 흐름을 정리합니다.',
  ],
  [
    '대상 확인',
    '지원 가능 여부와 신청 전 확인해야 할 조건을 점검합니다.',
    '기업은 의무대상 여부, 퇴직예정자 규모, 내부 담당 부서와 의사결정 흐름을 확인합니다. 개인 신청은 참여 가능 조건, 신청서 작성, 서명본 제출 가능 여부를 함께 확인합니다.',
  ],
  [
    '신청 안내',
    '서비스 유형에 맞춰 신청 방법과 준비자료를 안내합니다.',
    '기업 신청은 담당자 협의와 자료 준비 흐름을, 개인 신청은 양식 다운로드, 작성, 서명본 이메일 제출 절차를 중심으로 안내합니다. 불필요한 서류를 먼저 요구하지 않고 필요한 항목부터 정리합니다.',
  ],
  [
    '현황 파악',
    '기업 여건과 참여자 상황을 확인해 실제 진행 방식을 구체화합니다.',
    '기업컨설팅은 운영 현황, 대상자 발생 시점, 내부 안내 방식, 파일럿 필요성을 확인합니다. 커리어플래닝서비스는 참여자의 경력 상황과 진단·상담 운영 방식을 기준으로 준비합니다.',
  ],
  [
    '일정 조율',
    '담당자와 참여자의 시간을 고려해 무리 없는 진행 일정을 잡습니다.',
    '방문, 온라인 협의, 진단, 상담, 결과 정리 일정이 겹치지 않도록 조율합니다. 기업 내부 보고 일정이나 참여자 근무 여건도 함께 고려해 실행 가능한 일정으로 확정합니다.',
  ],
  [
    '서비스 진행',
    '기업컨설팅은 제도화와 운영체계, 커리어플래닝서비스는 경력진단과 경력설계를 중심으로 진행합니다.',
    '기업컨설팅은 현황 진단, 운영체계 설계, 파일럿 운영, 개선과제 정리를 중심으로 진행합니다. 커리어플래닝서비스는 진단 결과를 바탕으로 개인별 경력설계와 후속 준비 방향을 정리합니다.',
  ],
  [
    '결과 정리',
    '진행 결과와 후속 실행 과제를 정리해 다음 행동으로 연결합니다.',
    '기업에는 내부 운영에 활용할 수 있는 정리자료와 개선 과제를 안내합니다. 개인 참여자에게는 상담 결과, 경력설계 방향, 후속 준비사항을 중심으로 정리해 전달합니다.',
  ],
];
---
<BaseLayout title="진행 절차">
  <section class="ty-hero sub">
    <div class="ty-mark">진행 절차</div>
    <p class="ty-comment">문의부터 결과 정리까지</p>
    <h1>필요한 순서대로 확인하고,<br class="wide-break" /> 실행 가능한 방식으로 진행합니다.</h1>
    <p class="ty-lead">기업컨설팅과 커리어플래닝서비스는 신청 주체와 목적이 다릅니다. 먼저 지원 유형과 대상 여부를 확인한 뒤, 준비자료·일정·진행 방식을 맞춰갑니다.</p>
  </section>

  <section class="ty-section process-popover-section">
    <div class="ty-section-head">
      <h2>처음 문의하셔도 순서가 복잡하지 않도록 안내합니다.</h2>
      <p>기본 흐름은 일곱 단계입니다. 각 박스에 마우스를 올리면 실무 진행 기준을 확인할 수 있습니다.</p>
    </div>
    <div class="ty-process-list seven process-popover-list" aria-label="진행 절차">
      {steps.map(([title, body, detail], index) => (
        <article class="step-popover-card process-popover-card" tabindex="0" aria-describedby={`process-${index + 1}-detail`}>
          <span>{String(index + 1).padStart(2, '0')}</span>
          <h3>{title}</h3>
          <p>{body}</p>
          <div class="step-popover process-popover" id={`process-${index + 1}-detail`} role="tooltip">
            <strong>{title}</strong>
            <p>{detail}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
