---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${base}${path}`;
const serviceCards = [
  {
    label: '기업컨설팅',
    title: '제도 준비를 담당자가 설명할 수 있는 운영안으로 정리',
    body: '대상 여부, 내부 준비사항, 일정 조율, 운영체계 점검까지 기업 상황에 맞게 안내합니다.',
    href: link('business-consulting/'),
  },
  {
    label: '커리어플래닝서비스',
    title: '중장년 재직자의 경험과 다음 경력 방향 설계',
    body: '직무경험, 보유역량, 향후 역할 변화 가능성을 상담 중심으로 정리합니다.',
    href: link('career-planning/'),
  },
];
const process = [
  ['01', '대상 확인', '기업명, 희망 서비스, 참여 규모를 기준으로 가능 범위를 먼저 확인합니다.'],
  ['02', '준비 정리', '담당자 안내자료, 일정, 참여자 안내 방식 등 실행 전 준비사항을 구분합니다.'],
  ['03', '운영 진행', '기업컨설팅 또는 커리어플래닝서비스를 현장 여건에 맞춰 진행합니다.'],
  ['04', '결과 안내', '상담 결과와 후속 과제를 정리해 다음 행동을 확인할 수 있게 합니다.'],
];
---
<BaseLayout title="홈" description="케이잡스 K·JOBS가 재취업지원서비스 기업컨설팅과 커리어플래닝서비스의 대상 확인, 준비, 운영, 결과 정리를 지원합니다.">
  <section class="final-hero" aria-label="K·JOBS 재취업지원서비스 홈">
    <div class="final-hero-copy">
      <p class="apple-kicker">K·JOBS 재취업지원서비스 시행지원</p>
      <h1>기업의 준비와<br />참여자의 다음 경력을<br />한 번에 정리합니다.</h1>
      <p class="apple-subtitle">케이잡스는 기업컨설팅과 커리어플래닝서비스를 통해 대상 확인, 신청 준비, 일정 조율, 결과 정리까지 실행 가능한 흐름으로 안내합니다.</p>
      <div class="apple-links" aria-label="주요 행동">
        <a href={link('business-consulting/')}>기업컨설팅 보기 <span aria-hidden="true">〉</span></a>
        <a href={link('career-planning/')}>커리어플래닝서비스 보기 <span aria-hidden="true">〉</span></a>
        <a href={link('contact/')}>문의하기 <span aria-hidden="true">〉</span></a>
      </div>
    </div>

    <div class="final-hero-panel" aria-label="지원 구조 요약">
      <div class="panel-topline">
        <span>2026 시행지원</span>
        <strong>기업 · 참여자 동시 지원</strong>
      </div>
      <div class="panel-axis">
        <article>
          <span>For Company</span>
          <strong>기업컨설팅</strong>
          <p>제도 준비, 운영절차, 담당자 역할, 후속 과제를 정리합니다.</p>
        </article>
        <article>
          <span>For Participant</span>
          <strong>커리어플래닝서비스</strong>
          <p>경력진단, 역량점검, 목표설정, 실행계획을 상담으로 구체화합니다.</p>
        </article>
      </div>
      <div class="panel-flow">
        {process.map(([no, title]) => <span><em>{no}</em>{title}</span>)}
      </div>
    </div>
  </section>

  <section class="section final-services" aria-label="주요 서비스">
    <div class="section-heading">
      <span class="eyebrow">지원 서비스</span>
      <h2>필요한 서비스를 먼저 확인하세요.</h2>
      <p>재취업지원서비스는 기업의 제도 운영과 중장년 근로자의 경력 준비가 함께 맞물릴 때 효과가 커집니다.</p>
    </div>
    <div class="final-service-grid">
      {serviceCards.map((card) => (
        <article>
          <span class="tag">{card.label}</span>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
          <a href={card.href} class="text-link">자세히 보기</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section final-process" aria-label="진행 흐름">
    <div class="section-heading compact">
      <span class="eyebrow">진행 흐름</span>
      <h2>문의 후 바로 확인할 항목을 순서대로 정리합니다.</h2>
    </div>
    <div class="final-process-list">
      {process.map(([no, title, body]) => (
        <article>
          <span>{no}</span>
          <div>
            <h3>{title}</h3>
            <p>{body}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section cta-panel final-cta">
    <div>
      <span class="eyebrow light">문의 전 확인</span>
      <h2>기업명, 희망 서비스, 담당자 연락처만 준비해도 시작할 수 있습니다.</h2>
      <p>대상 여부와 준비사항을 먼저 확인한 뒤, 기업컨설팅 또는 커리어플래닝서비스 진행 가능 범위를 안내합니다.</p>
    </div>
    <a href={link('contact/')} class="btn inverse">문의 정보 확인</a>
  </section>
</BaseLayout>
