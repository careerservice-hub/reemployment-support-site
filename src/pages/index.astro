---
import BaseLayout from '../layouts/BaseLayout.astro';
import { homeJsonLd } from '../data/structuredData.js';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${base}${path}`;
const consultingFlow = [
  ['01', '신청 요건 확인', '지원대상, 신청자격, 제한사항을 먼저 확인합니다.', '재취업지원서비스 의무대상기업, 제도 도입·개선 희망 기업, 공동 도입 희망 기업인지 확인합니다. 100인 이상 기준, 공동 신청 기준, 참여 제한사항도 함께 봅니다.'],
  ['02', '운영체계 설계', '기업이 자체 시행할 수 있는 운영 절차를 설계합니다.', '담당자 역할, 대상자 안내, 프로그램 구성, 기록·성과관리 기준을 기업 상황에 맞게 정리합니다.'],
  ['03', '파일럿 운영', '설계한 운영안의 현장 적용 가능성을 확인합니다.', '일부 대상자에게 운영안을 시범 적용해 안내와 상담 절차를 점검합니다.'],
  ['04', '개선안 정리', '파일럿 결과와 현장 의견을 바탕으로 보완합니다.', '운영 중 확인된 쟁점, 담당자 의견, 참여자 반응을 정리해 기업별 제도화 과제로 연결합니다.'],
];
const careerFlow = [
  ['01', '참여 요건 확인', '지원 대상과 신청 방식을 먼저 확인합니다.', '지원 대상은 1,000인 미만 사업장에 재직 중인 40세 이상 중장년입니다. 공공부문은 제외되며, 예산 소진 시 조기 종료될 수 있습니다.'],
  ['02', '경력진단', '직무경험과 보유역량을 객관적으로 살펴봅니다.', '현재까지의 직무경험, 강점, 관심 분야, 변화 가능성을 확인해 상담의 출발점을 만듭니다.'],
  ['03', '상담 진행', '역할 변화와 다음 경력 방향을 구체화합니다.', '진단 결과를 바탕으로 향후 역할, 직무전환, 역량 보완 방향을 상담 중심으로 정리합니다.'],
  ['04', '실행계획 정리', '상담 이후 실천할 과제를 남깁니다.', '교육, 직무 준비, 경력목표, 후속 상담 필요사항을 정리해 참여자가 다음 행동을 확인할 수 있게 합니다.'],
];
---
<BaseLayout title="재취업지원서비스 시행지원" description="케이잡스 K·JOBS는 재취업지원서비스 시행지원과 경력지원서비스 관점에서 기업의 제도화, 중장년 경력설계와 경력전환 준비를 지원합니다." jsonLd={homeJsonLd}>
  <section class="ty-hero" aria-label="K·JOBS 재취업지원서비스 시행지원 홈">
    <div class="ty-mark">K·JOBS</div>
    <p class="ty-comment">재취업지원서비스 시행지원</p>
    <h1>재취업지원서비스를 통해<br />기업의 제도 운영과 중장년의 경력설계를 함께 준비합니다.</h1>
    <p class="ty-lead">케이잡스는 재취업지원서비스 시행지원을 중심으로<br class="wide-break" /> 재직 중 경력설계부터 경력전환 준비까지 이어지는 경력지원서비스를 안내합니다.</p>
    <div class="mobile-quick-card" aria-label="모바일 빠른 안내">
      <span>대상별 안내</span>
      <strong>먼저 해당되는 대상을 선택하세요.</strong>
      <p>해당하는 대상을 선택하면 서비스 내용과 신청 절차를 확인할 수 있습니다.</p>
      <div class="mobile-choice-grid">
        <a href={link('business-consulting/')}>기업 담당자 안내</a>
        <a href={link('career-planning/')}>개인 참여 안내</a>
      </div>
    </div>
    <div class="ty-actions audience-actions" aria-label="대상별 주요 안내">
      <a class="audience-action business" href={link('business-consulting/')}>
        <span>기업 담당자</span>
        <strong>기업컨설팅 안내</strong>
      </a>
      <a class="audience-action personal" href={link('career-planning/')}>
        <span>중장년 재직자</span>
        <strong>개인 참여 안내</strong>
      </a>
      <a class="audience-support-link" href={link('career-support/')}>서비스 전체 알아보기</a>
    </div>
  </section>

  <section class="ty-section" aria-label="서비스 개요">
    <div class="ty-section-head">
      <h2>기업컨설팅과 커리어플래닝서비스를 대상별로 안내합니다.</h2>
      <p>기업은 제도 운영체계를, 중장년 재직자는 앞으로의 경력 방향을 준비할 수 있습니다.</p>
    </div>
    <div class="ty-split-cards">
      <article class="consulting-image-card">
        <span>기업 제도화를 위한 지원</span>
        <h3>기업컨설팅</h3>
        <p>기업이 재취업지원서비스를 자체적으로 제도화하고 반복 운영할 수 있도록 운영체계, 절차, 파일럿 운영, 개선과제를 설계합니다.</p>
        <a href={link('business-consulting/')}>기업컨설팅 자세히 보기</a>
      </article>
      <article class="career-image-card">
        <span>중장년 재직자를 위한 지원</span>
        <h3>커리어플래닝서비스</h3>
        <p>중장년 재직자의 직무경험과 보유역량을 점검하고, 앞으로의 역할 변화와 경력 목표를 상담 중심으로 정리합니다.</p>
        <a href={link('career-planning/')}>커리어플래닝서비스 자세히 보기</a>
      </article>
    </div>
  </section>

  <section class="ty-section" aria-labelledby="career-support-home-title">
    <div class="ty-note-panel">
      <div>
        <p class="ty-comment">경력지원서비스</p>
        <h2 id="career-support-home-title">재직 중 경력설계부터 경력전환 준비까지 연결합니다.</h2>
        <p class="ty-lead">현재 공식 사업명은 ‘재취업지원서비스 시행지원’입니다. K·JOBS는 기업의 제도 운영과 참여자의 경력설계를 쉽게 이해할 수 있도록 ‘경력지원서비스’라는 확장 개념을 함께 사용합니다.</p>
      </div>
      <div class="ty-checks">
        <p><strong>경력진단</strong><span>직무경험과 보유역량 확인</span></p>
        <p><strong>경력설계</strong><span>다음 역할과 경력목표 설정</span></p>
        <p><strong>전환 준비</strong><span>역량 보완과 실행과제 정리</span></p>
        <p><strong>기업 제도화</strong><span>자체 운영체계와 절차 설계</span></p>
        <a class="ty-inline-link" href={link('career-support/')}>경력지원서비스 자세히 보기</a>
      </div>
    </div>
  </section>

  <section class="ty-section" aria-label="서비스별 진행 흐름">
    <div class="ty-section-head">
      <h2>서비스별 진행 절차를 확인하세요.</h2>
      <p>기업컨설팅은 제도 도입과 운영을, 커리어플래닝서비스는 개인의 경력진단과 설계를 중심으로 진행합니다.</p>
    </div>
    <div class="dual-flow-grid">
      <section class="flow-lane consulting" aria-label="기업컨설팅 흐름">
        <div class="flow-lane-head">
          <span>신청 요건 확인</span>
          <h3>기업컨설팅 흐름</h3>
          <p>의무대상기업과 제도 도입·개선 희망 기업이 신청 요건과 제한사항을 확인한 뒤, 자체 시행 체계를 설계합니다.</p>
          <div class="application-options" aria-label="기업컨설팅 신청 요건">
            <article class="step-popover-card application-pill" tabindex="0" aria-describedby="consulting-target-detail" data-mobile-detail>
              <strong>지원대상</strong>
              <span>의무대상·도입 희망 기업</span>
              <button class="mobile-detail-toggle" type="button" aria-expanded="false" aria-controls="consulting-target-detail">세부 내용 보기</button>
              <div class="step-popover" id="consulting-target-detail" role="tooltip">
                <strong>지원대상</strong>
                <p>재취업지원서비스 의무대상기업과 제도 도입·개선을 희망하는 기업이 대상입니다. 원·하청 관계사 또는 중소산업단지 내 기업이 공동으로 도입을 검토하는 경우도 포함됩니다.</p>
              </div>
            </article>
            <article class="step-popover-card application-pill" tabindex="0" aria-describedby="consulting-qualification-detail" data-mobile-detail>
              <strong>신청자격</strong>
              <span>100인 이상 기준 확인</span>
              <button class="mobile-detail-toggle" type="button" aria-expanded="false" aria-controls="consulting-qualification-detail">세부 내용 보기</button>
              <div class="step-popover" id="consulting-qualification-detail" role="tooltip">
                <strong>신청자격</strong>
                <p>재취업지원서비스 도입을 희망하는 전년도 기준 고용보험 피보험자수 100인 이상 기업이 기본 대상입니다. 공동 신청은 대표기업 100인 이상이면 참여기업은 100인 미만도 참여할 수 있습니다.</p>
              </div>
            </article>
            <article class="step-popover-card application-pill" tabindex="0" aria-describedby="consulting-apply-detail" data-mobile-detail>
              <strong>신청방법</strong>
              <span>온라인·이메일 신청</span>
              <button class="mobile-detail-toggle" type="button" aria-expanded="false" aria-controls="consulting-apply-detail">세부 내용 보기</button>
              <div class="step-popover" id="consulting-apply-detail" role="tooltip">
                <strong>신청방법</strong>
                <p>노사발전재단 누리집 온라인 신청 또는 이메일 신청 방식으로 접수합니다. 신청서, 사업자등록증, 고용보험 완납증명원, 개인정보 활용 동의서 등을 제출합니다.</p>
                <a class="popover-link" href="https://www.nosa.or.kr/portal/nosa/majorBiz/reEmpymnSport/entrprsCnsl" target="_blank" rel="noopener noreferrer">노사발전재단 기업컨설팅 페이지</a>
              </div>
            </article>
            <article class="step-popover-card application-pill" tabindex="0" aria-describedby="consulting-limit-detail" data-mobile-detail>
              <strong>신청제한</strong>
              <span>체납·공표기업 등 제외</span>
              <button class="mobile-detail-toggle" type="button" aria-expanded="false" aria-controls="consulting-limit-detail">세부 내용 보기</button>
              <div class="step-popover" id="consulting-limit-detail" role="tooltip">
                <strong>신청제한</strong>
                <p>중앙행정기관, 지방자치단체, 교육청 등 국가·지방행정기관은 참여할 수 없습니다. 중대산업재해 공표기업, 산업재해 발생건수 공표기업, 고용보험료 체납 또는 임금체불 기업도 제한됩니다.</p>
              </div>
            </article>
          </div>
        </div>
        <div class="flow-step-list">
          {consultingFlow.map(([num, title, body, detail]) => (
            <article class="step-popover-card compact" tabindex="0" aria-describedby={`home-consulting-${num}-detail`} data-mobile-detail>
              <span>{num}</span>
              <h4>{title}</h4>
              <p>{body}</p>
              <button class="mobile-detail-toggle" type="button" aria-expanded="false" aria-controls={`home-consulting-${num}-detail`}>세부 내용 보기</button>
              <div class="step-popover" id={`home-consulting-${num}-detail`} role="tooltip">
                <strong>{title}</strong>
                <p>{detail}</p>
              </div>
            </article>
          ))}
        </div>
      </section>
      <section class="flow-lane career" aria-label="커리어플래닝서비스 흐름">
        <div class="flow-lane-head">
          <span>신청 방식 확인</span>
          <h3>커리어플래닝서비스 흐름</h3>
          <p>기업 단위 또는 개인 단위로 신청할 수 있으며, 중장년 재직자의 경력과 다음 방향을 정리합니다.</p>
          <div class="application-options" aria-label="커리어플래닝서비스 신청 방식">
            <article class="step-popover-card application-pill" tabindex="0" aria-describedby="career-company-apply-detail" data-mobile-detail>
              <strong>기업단위 신청</strong>
              <span>기업 담당자 일괄 신청</span>
              <button class="mobile-detail-toggle" type="button" aria-expanded="false" aria-controls="career-company-apply-detail">세부 내용 보기</button>
              <div class="step-popover" id="career-company-apply-detail" role="tooltip">
                <strong>기업단위 신청</strong>
                <p>기업 담당자가 참여 소속 근로자를 일괄 신청합니다. 기업용 신청서, 신청 근로자 명단, 사업자등록증, 고용보험 완납증명원, 근로자별 동의서 등을 제출합니다.</p>
              </div>
            </article>
            <article class="step-popover-card application-pill" tabindex="0" aria-describedby="career-personal-apply-detail" data-mobile-detail>
              <strong>개인단위 신청</strong>
              <span>근로자 직접 신청</span>
              <button class="mobile-detail-toggle" type="button" aria-expanded="false" aria-controls="career-personal-apply-detail">세부 내용 보기</button>
              <div class="step-popover" id="career-personal-apply-detail" role="tooltip">
                <strong>개인단위 신청</strong>
                <p>개인 근로자가 케이잡스로 직접 신청합니다. 개인용 신청서와 개인정보 동의서, 재직증명서·고용보험 자격이력내역서·건강보험 자격득실확인서 등 재직 사실 증명 서류를 제출합니다.</p>
              </div>
            </article>
          </div>
        </div>
        <div class="flow-step-list">
          {careerFlow.map(([num, title, body, detail]) => (
            <article class="step-popover-card compact" tabindex="0" aria-describedby={`home-career-${num}-detail`} data-mobile-detail>
              <span>{num}</span>
              <h4>{title}</h4>
              <p>{body}</p>
              <button class="mobile-detail-toggle" type="button" aria-expanded="false" aria-controls={`home-career-${num}-detail`}>세부 내용 보기</button>
              <div class="step-popover" id={`home-career-${num}-detail`} role="tooltip">
                <strong>{title}</strong>
                <p>{detail}</p>
              </div>
            </article>
          ))}
        </div>
      </section>
    </div>
  </section>

  <section class="ty-cta">
    <p class="ty-comment">기업명, 희망 서비스와 연락처를 남겨 주세요</p>
    <h2>어떤 지원이 필요한지 상담해 드립니다.</h2>
    <a href={link('contact/')}>상담 문의하기</a>
  </section>
  <script is:inline>
    document.querySelectorAll('.mobile-detail-toggle').forEach((button) => {
      button.addEventListener('click', () => {
        const card = button.closest('[data-mobile-detail]');
        const isOpen = card?.dataset.mobileOpen === 'true';
        if (!card) return;
        card.dataset.mobileOpen = String(!isOpen);
        button.setAttribute('aria-expanded', String(!isOpen));
        button.textContent = isOpen ? '세부 내용 보기' : '세부 내용 닫기';
      });
    });
  </script>
</BaseLayout>
