---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${base}${path}`;
const features = [
  ['현황 진단', '기업의 대상자 규모, 운영 여건, 내부 준비 수준을 먼저 확인합니다.'],
  ['제도화 설계', '재취업지원서비스를 기업 안에서 시행할 수 있도록 운영체계와 절차를 정리합니다.'],
  ['파일럿 운영', '설계한 체계가 실제로 작동하는지 일부 대상자에게 시범 적용해 확인합니다.'],
  ['개선안 정리', '파일럿 결과와 현장 의견을 바탕으로 기업별 시행안을 보완합니다.'],
];
---
<BaseLayout title="홈" description="케이잡스 K·JOBS는 기업이 재취업지원서비스를 자체 제도화하고 시행할 수 있도록 기업컨설팅과 파일럿 운영을 지원합니다.">
  <section class="ty-hero" aria-label="K·JOBS 재취업지원서비스 기업컨설팅 홈">
    <div class="ty-mark">K·JOBS</div>
    <p class="ty-comment">재취업지원서비스 기업컨설팅</p>
    <h1>기업이 스스로 운영할 수 있는<br />재취업지원서비스 체계를 만듭니다.</h1>
    <p class="ty-lead">케이잡스는 기업이 재취업지원서비스를 자체 제도화하고 시행할 수 있도록 현황 진단, 운영체계 설계, 파일럿 운영, 개선안 정리를 지원합니다.</p>
    <div class="ty-actions" aria-label="주요 행동">
      <a href={link('business-consulting/')}>기업컨설팅 보기</a>
      <a href={link('career-planning/')}>커리어플래닝서비스 보기</a>
      <a href={link('contact/')}>문의하기</a>
    </div>
  </section>

  <section class="ty-section" aria-label="서비스 개요">
    <div class="ty-section-head">
      <h2>핵심은 대행 제공이 아니라 제도화입니다.</h2>
      <p>기업컨설팅은 재취업지원서비스를 대신 제공하는 사업이 아닙니다. 기업이 자체적으로 운영할 수 있도록 기준, 절차, 역할, 대상자 흐름을 설계하고 현장 적용 가능성을 확인하는 과정입니다.</p>
    </div>
    <div class="ty-split-cards">
      <article>
        <span>기업 제도화를 위한 지원</span>
        <h3>기업컨설팅</h3>
        <p>기업의 현재 여건을 진단하고 재취업지원서비스 시행체계, 운영 절차, 내부 역할, 후속 관리 방식을 설계합니다.</p>
        <a href={link('business-consulting/')}>자세히 보기</a>
      </article>
      <article>
        <span>컨설팅 안에서 검증하는 실행 단계</span>
        <h3>파일럿 운영</h3>
        <p>설계한 운영안이 실제 대상자에게 적용 가능한지 일부 프로그램을 시범 운영하고 보완점을 확인합니다.</p>
        <a href={link('process/')}>진행 절차 보기</a>
      </article>
    </div>
  </section>

  <section class="ty-section" aria-label="진행 흐름">
    <div class="ty-section-head">
      <h2>기업 맞춤형 시행안을 만드는 흐름입니다.</h2>
      <p>문의 이후에는 단순 상담 제공 여부가 아니라 기업이 어떤 방식으로 제도를 정착시킬 수 있는지를 순서대로 확인합니다.</p>
    </div>
    <div class="ty-feature-row">
      {features.map(([title, body]) => <article><h3>{title}</h3><p>{body}</p></article>)}
    </div>
  </section>

  <section class="ty-cta">
    <p class="ty-comment">기업명, 대상자 규모, 현재 준비 수준을 알려주시면 검토가 빠릅니다</p>
    <h2>먼저 기업의 제도화 가능 범위부터 확인하세요.</h2>
    <a href={link('contact/')}>문의 정보 확인</a>
  </section>
</BaseLayout>
