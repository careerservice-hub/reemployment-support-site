---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${base}${path}`;
const services = [
  {
    label: '01',
    title: '대상 확인',
    body: '신청 대상 여부와 준비 범위를 먼저 확인합니다.',
  },
  {
    label: '02',
    title: '기업 준비',
    body: '담당자가 실행할 수 있는 운영 흐름을 정리합니다.',
  },
  {
    label: '03',
    title: '커리어플래닝서비스',
    body: '참여자의 경험과 다음 경력 방향을 함께 설계합니다.',
  },
];
---
<BaseLayout title="홈">
  <section class="apple-hero" aria-label="K·JOBS 재취업지원서비스 홈">
    <div class="apple-hero-copy">
      <p class="apple-kicker">K·JOBS</p>
      <h1>재취업지원서비스,<br />준비부터 운영까지.</h1>
      <p class="apple-subtitle">기업의 제도 준비와 참여자의 커리어플래닝서비스를 간결하게 지원합니다.</p>
      <div class="apple-links" aria-label="주요 행동">
        <a href={link('business-consulting/')}>기업 지원 확인하기 <span aria-hidden="true">〉</span></a>
        <a href={link('contact/')}>문의하기 <span aria-hidden="true">〉</span></a>
      </div>
    </div>

    <div class="glass-ribbon" aria-hidden="true">
      <span class="ribbon-line one"></span>
      <span class="ribbon-line two"></span>
      <span class="ribbon-core"></span>
      <span class="ribbon-dot dot-a"></span>
      <span class="ribbon-dot dot-b"></span>
      <span class="ribbon-dot dot-c"></span>
    </div>

    <div class="apple-flow" aria-label="지원 흐름">
      <span>확인</span>
      <span>준비</span>
      <span>설계</span>
      <span>운영</span>
    </div>
  </section>

  <section class="apple-service-preview section" aria-label="주요 서비스">
    {services.map((service) => (
      <article>
        <span>{service.label}</span>
        <h2>{service.title}</h2>
        <p>{service.body}</p>
      </article>
    ))}
  </section>

  <section class="split-feature section apple-lower-content">
    <article>
      <span class="tag">기업 대상</span>
      <h2>기업컨설팅</h2>
      <p>제도 도입이나 운영 점검이 필요한 기업을 지원합니다. 신청 대상 여부, 담당자 역할, 일정 조율 범위를 현장 상황에 맞게 정리합니다.</p>
      <a href={link('business-consulting/')} class="text-link">기업 지원 보기</a>
    </article>
    <article>
      <span class="tag green">참여자 대상</span>
      <h2>커리어플래닝서비스</h2>
      <p>중장년 재직자가 경험과 역량을 정리하도록 돕습니다. 앞으로의 역할 변화에 맞춰 경력 목표와 실행계획을 구체화합니다.</p>
      <a href={link('career-planning/')} class="text-link">커리어플래닝서비스 보기</a>
    </article>
  </section>
</BaseLayout>
