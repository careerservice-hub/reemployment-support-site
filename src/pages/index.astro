---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${base}${path}`;
const consultingFlow = [
  ['01', '신청 요건 확인', '지원대상, 신청자격, 제한사항을 먼저 확인합니다.', '재취업지원서비스 의무대상기업, 제도 도입·개선 희망 기업, 공동 도입 희망 기업인지 확인합니다. 100인 이상 기준, 공동 신청 기준, 참여 제한사항도 함께 봅니다.'],
  ['02', '운영체계 설계', '기업이 자체 시행할 수 있는 운영 절차를 설계합니다.', '담당자 역할, 대상자 안내, 프로그램 구성, 기록·성과관리 기준을 기업 상황에 맞게 정리합니다.'],
  ['03', '파일럿 운영', '설계한 운영안의 현장 적용 가능성을 확인합니다.', '파일럿은 대행 제공이 아니라 검증 단계입니다. 일부 대상자에게 시범 적용해 안내와 상담 흐름이 실제로 작동하는지 봅니다.'],
  ['04', '개선안 정리', '파일럿 결과와 현장 의견을 바탕으로 보완합니다.', '운영 중 확인된 쟁점, 담당자 의견, 참여자 반응을 정리해 기업별 제도화 과제로 연결합니다.'],
];
const careerFlow = [
  ['01', '참여 요건 확인', '지원 대상과 신청 방식을 먼저 확인합니다.', '지원 대상은 1,000인 미만 사업장에 재직 중인 40세 이상 중장년입니다. 공공부문은 제외되며, 예산 소진 시 조기 종료될 수 있습니다.'],
  ['02', '경력진단', '직무경험과 보유역량을 객관적으로 살펴봅니다.', '현재까지의 직무경험, 강점, 관심 분야, 변화 가능성을 확인해 상담의 출발점을 만듭니다.'],
  ['03', '상담 진행', '역할 변화와 다음 경력 방향을 구체화합니다.', '진단 결과를 바탕으로 향후 역할, 직무전환, 역량 보완 방향을 상담 중심으로 정리합니다.'],
  ['04', '실행계획 정리', '상담 이후 실천할 과제를 남깁니다.', '교육, 직무 준비, 경력목표, 후속 상담 필요사항을 정리해 참여자가 다음 행동을 확인할 수 있게 합니다.'],
];
---
<BaseLayout title="홈" description="케이잡스 K·JOBS는 재취업지원서비스 시행지원 사업을 통해 기업컨설팅과 커리어플래닝서비스를 안내하고 운영합니다.">
  <section class="ty-hero" aria-label="K·JOBS 재취업지원서비스 시행지원 홈">
    <div class="ty-mark">K·JOBS</div>
    <p class="ty-comment">재취업지원서비스 시행지원</p>
    <h1>기업의 제도 운영과<br />중장년의 경력설계를 함께 준비합니다.</h1>
    <p class="ty-lead">케이잡스는 재취업지원서비스 시행지원 사업 안에서<br class="wide-break" /> 기업컨설팅과 커리어플래닝서비스를 기업과 참여자 관점에 맞게 안내합니다.</p>
    <div class="ty-actions" aria-label="주요 행동">
      <a href={link('business-consulting/')}>기업컨설팅 보기</a>
      <a href={link('career-planning/')}>커리어플래닝서비스 보기</a>
      <a href={link('contact/')}>문의하기</a>
    </div>
  </section>

  <section class="ty-section" aria-label="서비스 개요">
    <div class="ty-section-head">
      <h2>두 가지 지원을 한 흐름에서 확인합니다.</h2>
      <p>기업에는 제도화와 운영 준비가 필요하고, 참여자에게는 경력 진단과 다음 경력 방향이 필요합니다. 홈에서는 두 서비스를 구분해 검토할 수 있게 정리합니다.</p>
    </div>
    <div class="ty-split-cards">
      <article>
        <span>기업 제도화를 위한 지원</span>
        <h3>기업컨설팅</h3>
        <p>기업이 재취업지원서비스를 자체적으로 제도화하고 시행할 수 있도록 운영체계, 절차, 파일럿 운영, 개선과제를 설계합니다.</p>
        <a href={link('business-consulting/')}>기업컨설팅 자세히 보기</a>
      </article>
      <article>
        <span>중장년 재직자를 위한 지원</span>
        <h3>커리어플래닝서비스</h3>
        <p>중장년 재직자의 직무경험과 보유역량을 점검하고, 앞으로의 역할 변화와 경력 목표를 상담 중심으로 정리합니다.</p>
        <a href={link('career-planning/')}>커리어플래닝서비스 자세히 보기</a>
      </article>
    </div>
  </section>

  <section class="ty-section" aria-label="서비스별 진행 흐름">
    <div class="ty-section-head">
      <h2>필요한 지원 흐름을 나눠 확인합니다.</h2>
      <p>기업컨설팅은 기업의 제도화 흐름으로, 커리어플래닝서비스는 참여자의 경력설계 흐름으로 구분해 볼 수 있습니다.</p>
    </div>
    <div class="dual-flow-grid">
      <section class="flow-lane consulting" aria-label="기업컨설팅 흐름">
        <div class="flow-lane-head">
          <span>신청 요건 확인</span>
          <h3>기업컨설팅 흐름</h3>
          <p>의무대상기업과 제도 도입·개선 희망 기업이 신청 요건과 제한사항을 확인한 뒤, 자체 시행 체계를 설계합니다.</p>
          <div class="application-options" aria-label="기업컨설팅 신청 요건">
            <article class="step-popover-card application-pill" tabindex="0" aria-describedby="consulting-target-detail">
              <strong>지원대상</strong>
              <span>의무대상·도입 희망 기업</span>
              <div class="step-popover" id="consulting-target-detail" role="tooltip">
                <strong>지원대상</strong>
                <p>재취업지원서비스 의무대상기업과 제도 도입·개선을 희망하는 기업이 대상입니다. 원·하청 관계사 또는 중소산업단지 내 기업이 공동으로 도입을 검토하는 경우도 포함됩니다.</p>
              </div>
            </article>
            <article class="step-popover-card application-pill" tabindex="0" aria-describedby="consulting-qualification-detail">
              <strong>신청자격</strong>
              <span>100인 이상 기준 확인</span>
              <div class="step-popover" id="consulting-qualification-detail" role="tooltip">
                <strong>신청자격</strong>
                <p>재취업지원서비스 도입을 희망하는 전년도 기준 고용보험 피보험자수 100인 이상 기업이 기본 대상입니다. 공동 신청은 대표기업 100인 이상이면 참여기업은 100인 미만도 참여할 수 있습니다.</p>
              </div>
            </article>
            <article class="step-popover-card application-pill" tabindex="0" aria-describedby="consulting-apply-detail">
              <strong>신청방법</strong>
              <span>온라인·이메일 신청</span>
              <div class="step-popover" id="consulting-apply-detail" role="tooltip">
                <strong>신청방법</strong>
                <p>노사발전재단 누리집 온라인 신청 또는 이메일 신청 방식으로 접수합니다. 신청서, 사업자등록증, 고용보험 완납증명원, 개인정보활용동의서 등을 기준으로 확인합니다.</p>
              </div>
            </article>
            <article class="step-popover-card application-pill" tabindex="0" aria-describedby="consulting-limit-detail">
              <strong>신청제한</strong>
              <span>체납·공표기업 등 제외</span>
              <div class="step-popover" id="consulting-limit-detail" role="tooltip">
                <strong>신청제한</strong>
                <p>중앙행정기관, 지방자치단체, 교육청 등 국가·지방행정기관은 참여할 수 없습니다. 중대산업재해 공표기업, 산업재해 발생건수 공표기업, 고용보험료 체납 또는 임금체불 기업도 제한됩니다.</p>
              </div>
            </article>
          </div>
        </div>
        <div class="flow-step-list">
          {consultingFlow.map(([num, title, body, detail]) => (
            <article class="step-popover-card compact" tabindex="0" aria-describedby={`home-consulting-${num}-detail`}>
              <span>{num}</span>
              <h4>{title}</h4>
              <p>{body}</p>
              <div class="step-popover" id={`home-consulting-${num}-detail`} role="tooltip">
                <strong>{title}</strong>
                <p>{detail}</p>
              </div>
            </article>
          ))}
        </div>
      </section>
      <section class="flow-lane career" aria-label="커리어플래닝서비스 흐름">
        <div class="flow-lane-head">
          <span>신청 방식 확인</span>
          <h3>커리어플래닝서비스 흐름</h3>
          <p>기업 단위 또는 개인 단위로 신청할 수 있으며, 중장년 재직자의 경력과 다음 방향을 정리합니다.</p>
          <div class="application-options" aria-label="커리어플래닝서비스 신청 방식">
            <article class="step-popover-card application-pill" tabindex="0" aria-describedby="career-company-apply-detail">
              <strong>기업단위 신청</strong>
              <span>기업 담당자 일괄 신청</span>
              <div class="step-popover" id="career-company-apply-detail" role="tooltip">
                <strong>기업단위 신청</strong>
                <p>기업 담당자가 참여 소속 근로자를 일괄 신청합니다. 기업용 신청서, 신청 근로자 명단, 사업자등록증, 고용보험 완납증명원, 근로자별 동의서 등을 기준으로 접수합니다.</p>
              </div>
            </article>
            <article class="step-popover-card application-pill" tabindex="0" aria-describedby="career-personal-apply-detail">
              <strong>개인단위 신청</strong>
              <span>근로자 직접 신청</span>
              <div class="step-popover" id="career-personal-apply-detail" role="tooltip">
                <strong>개인단위 신청</strong>
                <p>개인 근로자가 수행기관으로 직접 신청합니다. 개인용 신청서와 개인정보 동의서, 재직증명서·고용보험 자격이력내역서·건강보험 자격득실확인서 등 재직 사실 증명 서류를 확인합니다.</p>
              </div>
            </article>
          </div>
        </div>
        <div class="flow-step-list">
          {careerFlow.map(([num, title, body, detail]) => (
            <article class="step-popover-card compact" tabindex="0" aria-describedby={`home-career-${num}-detail`}>
              <span>{num}</span>
              <h4>{title}</h4>
              <p>{body}</p>
              <div class="step-popover" id={`home-career-${num}-detail`} role="tooltip">
                <strong>{title}</strong>
                <p>{detail}</p>
              </div>
            </article>
          ))}
        </div>
      </section>
    </div>
  </section>

  <section class="ty-cta">
    <p class="ty-comment">기업명, 희망 서비스, 담당자 연락처를 알려주시면 확인이 빠릅니다</p>
    <h2>먼저 필요한 지원 유형부터 확인하세요.</h2>
    <a href={link('contact/')}>문의 정보 확인</a>
  </section>
</BaseLayout>
