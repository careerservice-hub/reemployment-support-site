---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${base}${path}`;
const services = [
  {
    label: '제도 준비',
    title: '대상 확인',
    body: '신청 대상 여부와 준비 범위를 먼저 확인합니다. 기업 상황에 맞춰 필요한 절차를 정리합니다.',
  },
  {
    label: '기업 지원',
    title: '기업 준비',
    body: '담당자가 내부 안내와 일정 조율을 진행할 수 있도록 운영 기준을 쉽게 정리합니다.',
  },
  {
    label: '참여자 지원',
    title: '경력설계',
    body: '참여자의 직무경험과 강점을 확인합니다. 다음 경력 방향과 실행 과제를 함께 정리합니다.',
  },
];
---
<BaseLayout title="홈">
  <section class="hero section-xl">
    <div class="hero-content">
      <div class="eyebrow">K·JOBS 시행지원</div>
      <h1>기업의 제도 준비와 참여자의 경력설계를 함께 지원합니다.</h1>
      <p class="hero-copy">신청 대상 여부부터 운영 준비까지 함께 확인합니다. 기업컨설팅과 커리어플래닝서비스를 한 흐름으로 안내합니다.</p>
      <div class="support-points" aria-label="핵심 지원 항목">
        <span>대상 여부 확인</span>
        <span>기업 부담 완화</span>
        <span>경력설계 지원</span>
      </div>
      <div class="hero-actions">
        <a class="btn primary" href={link('business-consulting/')}>기업 지원 확인</a>
        <a class="btn secondary" href={link('career-planning/')}>경력설계 보기</a>
      </div>
    </div>
    <div class="hero-visual" aria-label="케이잡스 재취업지원서비스 시행지원 흐름">
      <div class="visual-card">
        <span class="visual-label">지원 흐름</span>
        <strong>확인하고, 준비하고, 실행합니다.</strong>
        <p>확정되지 않은 내용은 단정하지 않습니다. 기업 상황과 희망 서비스에 맞춰 확인·안내·지원합니다.</p>
      </div>
      <div class="visual-branches">
        <article>
          <span>기업컨설팅</span>
          <strong>기업 준비</strong>
          <p>대상 검토, 담당자 준비, 일정 조율, 결과 관리 기준 확인</p>
        </article>
        <article>
          <span>커리어플래닝서비스</span>
          <strong>경력설계</strong>
          <p>직무경험 점검, 강점 정리, 경력 목표와 실행계획 수립</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section service-strip" aria-label="주요 서비스">
    {services.map((service) => (
      <article>
        <span>{service.label}</span>
        <h2>{service.title}</h2>
        <p>{service.body}</p>
      </article>
    ))}
  </section>

  <section class="split-feature section">
    <article>
      <span class="tag">기업 대상</span>
      <h2>기업컨설팅</h2>
      <p>제도 도입이나 운영 점검이 필요한 기업을 지원합니다. 신청 대상 여부, 담당자 역할, 일정 조율 범위를 현장 상황에 맞게 정리합니다.</p>
      <a href={link('business-consulting/')} class="text-link">기업 지원 보기</a>
    </article>
    <article>
      <span class="tag green">참여자 대상</span>
      <h2>커리어플래닝서비스</h2>
      <p>중장년 재직자가 경험과 역량을 정리하도록 돕습니다. 앞으로의 역할 변화에 맞춰 경력 목표와 실행계획을 구체화합니다.</p>
      <a href={link('career-planning/')} class="text-link">경력설계 보기</a>
    </article>
  </section>

  <section class="section">
    <div class="section-heading">
      <span class="eyebrow">K·JOBS 지원 원칙</span>
      <h2>공식 기준은 정확하게, 현장 안내는 쉽게 정리합니다.</h2>
      <p>케이잡스는 수행기관 관점에서 필요한 항목을 정돈합니다. 기업 담당자와 참여자가 준비할 일을 쉬운 순서로 안내합니다.</p>
    </div>
    <div class="cards four">
      <article class="card"><strong>대상 확인</strong><p>기업과 참여자의 대상 여부, 신청 방식, 사전 준비사항을 먼저 확인합니다.</p></article>
      <article class="card"><strong>운영 설계</strong><p>기업 여건에 맞춰 일정, 안내 방식, 프로그램 구성 기준을 정리합니다.</p></article>
      <article class="card"><strong>경력 상담</strong><p>참여자의 직무경험, 강점, 필요 역량을 확인해 경력 방향을 잡습니다.</p></article>
      <article class="card"><strong>결과 정리</strong><p>상담 결과와 실행 과제를 정리하고 후속 안내가 가능하도록 돕습니다.</p></article>
    </div>
  </section>

  <section class="cta-panel section">
    <div>
      <span class="eyebrow light">다음 단계</span>
      <h2>우리 기업에 맞는 참여 가능 여부를 확인하세요.</h2>
      <p>기업 상황과 희망 서비스에 맞춰 대상 여부와 준비사항을 안내합니다.</p>
    </div>
    <a class="btn inverse" href={link('contact/')}>문의하기</a>
  </section>
</BaseLayout>
