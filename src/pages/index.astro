---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${base}${path}`;
const features = [
  ['대상 확인', '기업명과 희망 서비스를 기준으로 가능 범위를 먼저 확인합니다.'],
  ['준비 정리', '담당자 안내, 참여자 안내, 일정 조율에 필요한 항목을 정리합니다.'],
  ['운영 진행', '기업컨설팅과 커리어플래닝서비스를 현장 여건에 맞춰 진행합니다.'],
  ['결과 안내', '상담 결과와 후속 과제를 다음 행동으로 연결합니다.'],
];
---
<BaseLayout title="홈" description="케이잡스 K·JOBS가 재취업지원서비스 기업컨설팅과 커리어플래닝서비스의 대상 확인, 준비, 운영, 결과 정리를 지원합니다.">
  <section class="ty-hero" aria-label="K·JOBS 재취업지원서비스 홈">
    <div class="ty-mark">K·JOBS</div>
    <p class="ty-comment">재취업지원서비스 시행지원을 더 단순하게</p>
    <h1>준비부터 운영까지.</h1>
    <p class="ty-lead">기업컨설팅과 커리어플래닝서비스를 한 흐름으로 정리합니다.</p>
    <div class="ty-actions" aria-label="주요 행동">
      <a href={link('business-consulting/')}>기업컨설팅</a>
      <a href={link('career-planning/')}>커리어플래닝서비스</a>
      <a href={link('contact/')}>문의하기</a>
    </div>
  </section>

  <section class="ty-section" aria-label="서비스 개요">
    <div class="ty-section-head">
      <h2>읽기 쉽고 실행 가능하게</h2>
      <p>담당자가 이해하고, 설명하고, 바로 실행할 수 있게 복잡한 제도 운영을 단순한 순서로 바꿉니다.</p>
    </div>
    <div class="ty-split-cards">
      <article>
        <span>기업을 위한 지원</span>
        <h3>기업컨설팅</h3>
        <p>대상 여부, 내부 준비, 일정 조율, 운영체계 점검을 기업 상황에 맞게 정리합니다.</p>
        <a href={link('business-consulting/')}>자세히 보기</a>
      </article>
      <article>
        <span>참여자를 위한 지원</span>
        <h3>커리어플래닝서비스</h3>
        <p>중장년 재직자의 직무경험, 보유역량, 다음 경력 방향을 상담 중심으로 정리합니다.</p>
        <a href={link('career-planning/')}>자세히 보기</a>
      </article>
    </div>
  </section>

  <section class="ty-section" aria-label="진행 흐름">
    <div class="ty-section-head">
      <h2>단순하지만 실제적으로</h2>
      <p>문의 후 확인해야 할 항목을 네 단계로 압축합니다.</p>
    </div>
    <div class="ty-feature-row">
      {features.map(([title, body]) => <article><h3>{title}</h3><p>{body}</p></article>)}
    </div>
  </section>

  <section class="ty-cta">
    <p class="ty-comment">기업명, 희망 서비스, 담당자 연락처만 있어도 시작할 수 있습니다</p>
    <h2>확인부터 시작하세요.</h2>
    <a href={link('contact/')}>문의 정보 확인</a>
  </section>
</BaseLayout>
