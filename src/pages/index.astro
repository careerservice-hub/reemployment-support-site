---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const link = (path) => `${base}${path}`;
const services = [
  {
    label: '시행지원',
    title: '재취업지원서비스',
    body: '기업이 제도 취지와 운영 기준을 이해하고, 대상자 안내부터 결과 정리까지 준비할 수 있도록 지원합니다.',
  },
  {
    label: '기업 대상',
    title: '기업컨설팅',
    body: '인력 구조와 운영 여건을 확인해 담당자 안내, 프로그램 구성, 후속 관리 기준을 함께 정리합니다.',
  },
  {
    label: '개인 대상',
    title: '커리어플래닝서비스',
    body: '중장년 재직자의 직무경험과 강점을 점검하고, 경력목표와 실행계획을 구체화합니다.',
  },
];
---
<BaseLayout title="홈">
  <section class="hero section-xl">
    <div class="hero-content">
      <div class="eyebrow">K·JOBS Enterprise Support</div>
      <h1>재취업지원서비스를 기업 현장에서 실행 가능하게 정리합니다.</h1>
      <p class="hero-copy">케이잡스는 기업의 재취업지원서비스 시행지원, 기업컨설팅, 커리어플래닝서비스를 수행기관 관점에서 연결합니다. 기업 담당자는 절차와 준비사항을 명확히 확인하고, 중장년 재직자는 자신의 경력 방향을 단계적으로 설계할 수 있습니다.</p>
      <div class="hero-actions">
        <a class="btn primary" href={link('business-consulting/')}>기업컨설팅 확인</a>
        <a class="btn secondary" href={link('career-planning/')}>커리어플래닝서비스 보기</a>
      </div>
    </div>
    <div class="hero-visual" aria-label="케이잡스 재취업지원서비스 시행지원 흐름">
      <div class="visual-card">
        <span class="visual-label">K-JOBS ENTERPRISE</span>
        <strong>기업 담당자와 참여자를 같은 절차 안에서 지원합니다.</strong>
        <p>대상 확인, 일정 조율, 상담 진행, 결과 정리를 한 흐름으로 안내합니다.</p>
      </div>
      <div class="visual-steps">
        <span>대상 확인</span>
        <span>운영 설계</span>
        <span>상담 진행</span>
      </div>
    </div>
  </section>

  <section class="section service-strip" aria-label="주요 서비스">
    {services.map((service) => (
      <article>
        <span>{service.label}</span>
        <h2>{service.title}</h2>
        <p>{service.body}</p>
      </article>
    ))}
  </section>

  <section class="split-feature section">
    <article>
      <span class="tag">For Company</span>
      <h2>기업컨설팅</h2>
      <p>제도 도입을 준비하거나 운영 방식을 점검해야 하는 기업을 위해 대상자 안내, 프로그램 구성, 담당자 운영 기준을 현장 상황에 맞게 정리합니다.</p>
      <a href={link('business-consulting/')} class="text-link">기업 지원 내용 확인</a>
    </article>
    <article>
      <span class="tag green">For Individual</span>
      <h2>커리어플래닝서비스</h2>
      <p>중장년 재직자가 지금까지의 경험과 역량을 정리하고, 앞으로의 직무 변화와 경력 목표를 구체화하도록 개인별 상담 흐름을 제공합니다.</p>
      <a href={link('career-planning/')} class="text-link">개인 지원 내용 확인</a>
    </article>
  </section>

  <section class="section">
    <div class="section-heading">
      <span class="eyebrow">K·JOBS Approach</span>
      <h2>공식 기준은 정확하게, 현장 안내는 이해하기 쉽게.</h2>
      <p>케이잡스는 고용노동부 위탁 사업의 공신력을 해치지 않으면서도, 기업 담당자와 참여자가 실제로 준비해야 할 항목을 쉬운 언어로 정리합니다.</p>
    </div>
    <div class="cards four">
      <article class="card"><strong>대상 확인</strong><p>기업과 참여자의 대상 여부, 신청 방식, 사전 준비사항을 먼저 확인합니다.</p></article>
      <article class="card"><strong>운영 설계</strong><p>기업 여건에 맞춰 일정, 안내 방식, 프로그램 구성 기준을 정리합니다.</p></article>
      <article class="card"><strong>경력 상담</strong><p>참여자의 직무경험, 강점, 필요 역량을 확인해 경력 방향을 잡습니다.</p></article>
      <article class="card"><strong>결과 정리</strong><p>상담 결과와 실행 과제를 정리하고 후속 안내가 가능하도록 돕습니다.</p></article>
    </div>
  </section>

  <section class="cta-panel section">
    <div>
      <span class="eyebrow light">Next Step</span>
      <h2>참여 가능 여부와 진행 방식을 먼저 확인하세요.</h2>
      <p>기업컨설팅 또는 커리어플래닝서비스 참여를 검토 중이라면, 대상 여부와 준비사항을 케이잡스와 먼저 확인할 수 있습니다.</p>
    </div>
    <a class="btn inverse" href={link('contact/')}>문의하기</a>
  </section>
</BaseLayout>
