---
import BaseLayout from '../layouts/BaseLayout.astro';
import { contactJsonLd } from '../data/structuredData.js';
---
<BaseLayout title="문의" description="재취업지원서비스 기업컨설팅과 커리어플래닝서비스 상담 가능 여부, 준비자료, 일정 확인을 문의할 수 있습니다." jsonLd={contactJsonLd}>
  <section class="ty-hero sub">
    <div class="ty-mark">문의 안내</div>
    <p class="ty-comment">필요한 서비스를 상담해 드립니다</p>
    <h1>필요한 상담을 남겨 주세요.</h1>
    <p class="ty-lead">기업컨설팅 또는 커리어플래닝서비스를 검토 중이라면 상담 유형을 선택하고 기본 정보를 남겨 주세요. 담당자가 확인 후 연락드립니다.</p>
  </section>

  <section class="ty-section ty-contact-card">
    <div>
      <p class="ty-comment">문의 안내</p>
      <h2>케이잡스</h2>
      <p>2026년 재취업지원서비스 시행지원 수행기관</p>
    </div>
    <div class="ty-contact-lines">
      <p><strong>문의 이메일</strong><span>h.douze@kjobs.co.kr</span></p>
      <p><strong>대표 연락처</strong><span>02-797-5659 / 010-5747-8286</span></p>
      <p><strong>상담 분야</strong><span>기업컨설팅, 커리어플래닝서비스, 신청 전 확인, 준비자료 안내</span></p>
      <p><strong>개인 신청</strong><span><a href="/career-planning/">커리어플래닝서비스 안내 페이지</a>에서 신청 양식을 내려받아 이메일로 제출합니다.</span></p>
    </div>
  </section>

  <section class="ty-section consultation-section" id="consultation-request">
    <div class="ty-section-head">
      <p class="ty-comment">상담신청</p>
      <h2>상담 유형을 선택하고 연락받을 정보를 입력해 주세요.</h2>
      <p>아래 내용은 상담 신청 확인과 연락을 위한 최소 정보입니다. 주민등록번호, 건강정보, 급여자료, 퇴직자 명단 등 민감정보는 입력하지 마세요.</p>
    </div>

    <form class="consultation-form" id="consultationForm" novalidate>
      <input type="text" name="website" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />

      <fieldset class="consultation-type" aria-label="상담 유형 선택">
        <legend>상담 유형</legend>
        <label>
          <input type="radio" name="serviceType" value="business" checked />
          <span>
            <strong>기업컨설팅</strong>
            <small>기업의 재취업지원서비스 제도화·운영체계 상담</small>
          </span>
        </label>
        <label>
          <input type="radio" name="serviceType" value="career" />
          <span>
            <strong>커리어플래닝서비스</strong>
            <small>개인 또는 기업 단위 경력진단·경력설계 상담</small>
          </span>
        </label>
        <label>
          <input type="radio" name="serviceType" value="general" />
          <span>
            <strong>기타 문의</strong>
            <small>자료 요청, 일정 확인, 기타 문의</small>
          </span>
        </label>
      </fieldset>

      <div class="form-grid">
        <label>
          <span>성명 또는 담당자명 <b>*</b></span>
          <input type="text" name="name" required autocomplete="name" placeholder="예: 홍길동" />
        </label>
        <label class="company-field">
          <span>기업명</span>
          <input type="text" name="company" autocomplete="organization" placeholder="예: ○○산업" />
        </label>
        <label>
          <span>연락처 <b>*</b></span>
          <input type="tel" name="phone" required autocomplete="tel" placeholder="예: 010-0000-0000" />
        </label>
        <label>
          <span>이메일 <b>*</b></span>
          <input type="email" name="email" required autocomplete="email" placeholder="예: name@example.com" />
        </label>
      </div>

      <div class="conditional-fields" data-panel="business">
        <div class="form-grid compact">
          <label>
            <span>상시근로자 규모</span>
            <select name="employeeSize">
              <option value="">선택 안 함</option>
              <option>100명 미만</option>
              <option>100~299명</option>
              <option>300~999명</option>
              <option>1,000명 이상</option>
            </select>
          </label>
          <label>
            <span>기존 재취업지원서비스 운영 여부</span>
            <select name="existingService">
              <option value="">선택 안 함</option>
              <option>운영 중</option>
              <option>준비 중</option>
              <option>운영하지 않음</option>
              <option>확인 필요</option>
            </select>
          </label>
          <label>
            <span>노사발전재단 기업컨설팅 신청 여부</span>
            <select name="foundationStatus">
              <option value="">선택 안 함</option>
              <option>신청 전 검토 중</option>
              <option>신청 예정</option>
              <option>신청 완료</option>
              <option>확인 필요</option>
            </select>
          </label>
          <label>
            <span>퇴직예정자·50세 이상 근로자 관련 문의</span>
            <select name="olderWorkerInquiry">
              <option value="">선택 안 함</option>
              <option>있음</option>
              <option>없음</option>
              <option>확인 필요</option>
            </select>
          </label>
        </div>
      </div>

      <div class="conditional-fields" data-panel="career" hidden>
        <div class="form-grid compact">
          <label>
            <span>신청 구분</span>
            <select name="applicationType">
              <option value="">선택 안 함</option>
              <option>개인 신청 문의</option>
              <option>기업 단위 신청 문의</option>
              <option>신청 방법 확인</option>
            </select>
          </label>
          <label>
            <span>재직 여부</span>
            <select name="employmentStatus">
              <option value="">선택 안 함</option>
              <option>재직 중</option>
              <option>퇴직 예정</option>
              <option>퇴직 후 확인 필요</option>
            </select>
          </label>
          <label>
            <span>희망 상담 내용</span>
            <select name="careerInterest">
              <option value="">선택 안 함</option>
              <option>경력진단</option>
              <option>경력설계서 작성</option>
              <option>신청 가능 여부</option>
              <option>기업 단위 운영 문의</option>
            </select>
          </label>
          <label>
            <span>희망 일정</span>
            <input type="text" name="preferredSchedule" placeholder="예: 7월 중, 평일 오후" />
          </label>
        </div>
      </div>

      <label class="message-field">
        <span>상담 희망 내용 <b>*</b></span>
        <textarea name="message" required rows="6" minlength="10" placeholder="상담 받고 싶은 내용을 간단히 적어 주세요. 민감정보나 내부 인사자료는 입력하지 마세요."></textarea>
      </label>

      <div class="privacy-box">
        <strong>개인정보 수집·이용 안내</strong>
        <p>필수 항목: 성명 또는 담당자명, 연락처, 이메일, 상담 유형과 상담 내용</p>
        <p>선택 항목: 기업명과 상담 유형별 추가 입력정보</p>
        <p>수집 목적: 상담 신청 확인, 대상 여부·준비자료·일정 안내, 문의 회신</p>
        <p>보유 기간: 상담과 문의 대응이 끝난 날부터 3개월 후 파기</p>
        <p>동의를 거부할 수 있으나, 이 경우 홈페이지 상담신청 기능을 이용할 수 없습니다. 이메일 또는 전화 문의는 가능합니다.</p>
        <p><a class="ty-inline-link" href="/privacy/" target="_blank" rel="noopener noreferrer">개인정보처리방침 자세히 보기</a></p>
        <label class="privacy-check">
          <input type="checkbox" name="privacyConsent" required />
          <span>개인정보 수집·이용에 동의합니다. <b>*</b></span>
        </label>
      </div>

      <div class="form-actions">
        <button type="submit" class="consultation-submit">상담신청 보내기</button>
        <p id="formStatus" role="status" aria-live="polite">입력 내용을 확인한 뒤 상담신청을 보내 주세요.</p>
      </div>
    </form>
  </section>

  <section class="ty-section">
    <div class="ty-section-head">
      <h2>문의 전 확인사항</h2>
      <p>아래 내용을 미리 확인하면 대상 여부와 일정을 더 빠르게 안내받을 수 있습니다.</p>
    </div>
    <div class="ty-list-grid">
      <p><strong>기업컨설팅</strong> 희망 여부와 현재 제도 운영 상황</p>
      <p><strong>커리어플래닝서비스</strong> 참여 예상 인원과 희망 일정</p>
      <p><strong>담당자 정보</strong> 성함, 부서, 연락 가능한 시간대</p>
      <p><strong>기타 요청사항</strong> 내부 보고, 설명회, 자료 요청 등 사전 확인이 필요한 내용</p>
    </div>
  </section>

  <script is:inline>
    const form = document.getElementById('consultationForm');
    const statusEl = document.getElementById('formStatus');
    const panels = [...document.querySelectorAll('[data-panel]')];
    const serviceLabels = {
      business: '기업컨설팅',
      career: '커리어플래닝서비스',
      general: '기타 문의',
    };

    function activeService() {
      return form.querySelector('input[name="serviceType"]:checked')?.value || 'business';
    }

    function updatePanels() {
      const service = activeService();
      panels.forEach((panel) => {
        panel.hidden = panel.dataset.panel !== service;
      });
    }

    function getValue(data, key) {
      return (data.get(key) || '').toString().trim();
    }

    function buildSummary(data) {
      const service = activeService();
      const lines = [
        `[재취업지원서비스 상담신청]`,
        ``,
        `상담유형: ${serviceLabels[service]}`,
        `성명/담당자: ${getValue(data, 'name')}`,
        `기업명: ${getValue(data, 'company') || '미입력'}`,
        `연락처: ${getValue(data, 'phone')}`,
        `이메일: ${getValue(data, 'email')}`,
      ];

      if (service === 'business') {
        lines.push(
          ``,
          `기업 규모: ${getValue(data, 'employeeSize') || '미입력'}`,
          `기존 운영 여부: ${getValue(data, 'existingService') || '미입력'}`,
          `재단 컨설팅 신청 여부: ${getValue(data, 'foundationStatus') || '미입력'}`,
          `퇴직예정자/50세 이상 관련 문의: ${getValue(data, 'olderWorkerInquiry') || '미입력'}`,
          `문의 유형: 기업컨설팅`
        );
      }

      if (service === 'career') {
        lines.push(
          ``,
          `신청 구분: ${getValue(data, 'applicationType') || '미입력'}`,
          `재직 여부: ${getValue(data, 'employmentStatus') || '미입력'}`,
          `희망 상담: ${getValue(data, 'careerInterest') || '미입력'}`,
          `희망 일정: ${getValue(data, 'preferredSchedule') || '미입력'}`,
          `문의 유형: 커리어플래닝서비스`
        );
      }

      lines.push(
        ``,
        `상담 희망 내용:`,
        `${getValue(data, 'message')}`,
        ``,
        `개인정보 동의: 동의함`,
        `접수 경로: 홈페이지 상담신청`
      );

      return lines.join('\n');
    }

    form.addEventListener('change', updatePanels);
    updatePanels();

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const data = new FormData(form);

      if (getValue(data, 'website')) return;

      if (!form.checkValidity()) {
        form.reportValidity();
        statusEl.textContent = '필수 항목과 개인정보 동의를 확인해 주세요.';
        return;
      }

      const payload = Object.fromEntries(data.entries());
      payload.privacyConsent = data.get('privacyConsent') === 'on';

      const submitButton = form.querySelector('button[type="submit"]');
      submitButton.disabled = true;
      submitButton.textContent = '전송 중입니다';
      statusEl.textContent = '상담 내용을 전송하고 있습니다.';

      try {
        const response = await fetch('https://kjobs-consultation-alert.kjobs-alert.workers.dev', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const result = await response.json().catch(() => ({}));
        if (!response.ok || !result.ok) {
          throw new Error(result.error || 'send_failed');
        }
        statusEl.textContent = '상담신청이 전송되었습니다. 담당자 확인 후 연락드리겠습니다.';
        form.reset();
        updatePanels();
      } catch (error) {
        const body = buildSummary(data);
        const subject = `[상담신청] ${serviceLabels[activeService()]} - ${getValue(data, 'name')}`;
        const mailto = `mailto:h.douze@kjobs.co.kr?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
        statusEl.textContent = '상담신청을 바로 전송하지 못했습니다. 이메일 작성 화면에서 내용을 확인한 뒤 보내 주세요.';
        window.location.href = mailto;
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = '상담신청 보내기';
      }
    });
  </script>
</BaseLayout>
